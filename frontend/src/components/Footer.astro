---

---

<footer class="border-t border-white/5 py-12">
    <div class="container-premium">
        <div class="grid md:grid-cols-4 gap-8 mb-10">
            <!-- Brand -->
            <div class="md:col-span-1">
                <a href="/" class="flex items-center gap-2 mb-4">
                    <div
                        class="w-8 h-8 bg-white rounded-lg flex items-center justify-center"
                    >
                        <svg
                            class="w-4 h-4 text-[#0c0c0f]"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                        >
                            <path
                                d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"
                                stroke-linecap="round"
                                stroke-linejoin="round"></path>
                        </svg>
                    </div>
                    <span class="text-base font-semibold text-white"
                        >GenApps</span
                    >
                </a>
                <p class="text-sm text-[#7a7a82] leading-relaxed">
                    Build stunning websites with AI. No coding required.
                </p>
            </div>

            <!-- Product -->
            <div>
                <h4 class="text-sm font-semibold text-white mb-4">Product</h4>
                <ul class="space-y-3">
                    <li>
                        <a
                            href="/builder"
                            class="text-sm text-[#7a7a82] hover:text-white transition-colors"
                            >Builder</a
                        >
                    </li>
                    <li>
                        <a
                            href="/templates"
                            class="text-sm text-[#7a7a82] hover:text-white transition-colors"
                            >Templates</a
                        >
                    </li>
                    <li>
                        <a
                            href="/pricing"
                            class="text-sm text-[#7a7a82] hover:text-white transition-colors"
                            >Pricing</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Company -->
            <div>
                <h4 class="text-sm font-semibold text-white mb-4">Company</h4>
                <ul class="space-y-3">
                    <li>
                        <a
                            href="/about"
                            class="text-sm text-[#7a7a82] hover:text-white transition-colors"
                            >About</a
                        >
                    </li>
                    <li>
                        <a
                            href="/faq"
                            class="text-sm text-[#7a7a82] hover:text-white transition-colors"
                            >FAQ</a
                        >
                    </li>
                    <li>
                        <a
                            href="/contact"
                            class="text-sm text-[#7a7a82] hover:text-white transition-colors"
                            >Contact</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Legal -->
            <div>
                <h4 class="text-sm font-semibold text-white mb-4">Legal</h4>
                <ul class="space-y-3">
                    <li>
                        <a
                            href="/terms"
                            class="text-sm text-[#7a7a82] hover:text-white transition-colors"
                            >Terms</a
                        >
                    </li>
                    <li>
                        <a
                            href="/privacy"
                            class="text-sm text-[#7a7a82] hover:text-white transition-colors"
                            >Privacy</a
                        >
                    </li>
                    <li>
                        <a
                            href="/refund"
                            class="text-sm text-[#7a7a82] hover:text-white transition-colors"
                            >Refund Policy</a
                        >
                    </li>
                </ul>
            </div>
        </div>

        <!-- Bottom Bar -->
        <div
            class="pt-8 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-4"
        >
            <p class="text-xs text-[#55555d]">
                © 2024 GenApps.online. Operated by MUNEEB UR REHMAN. Payments by
                Paddle.
            </p>
            <div class="flex items-center gap-6">
                <a
                    href="https://twitter.com"
                    target="_blank"
                    class="text-[#55555d] hover:text-white transition-colors"
                >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
                        ><path
                            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                        ></path></svg
                    >
                </a>
                <a
                    href="https://github.com"
                    target="_blank"
                    class="text-[#55555d] hover:text-white transition-colors"
                >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
                        ><path
                            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
                        ></path></svg
                    >
                </a>
            </div>
        </div>
    </div>
</footer>
