---

---

<!-- Auth Modal -->
<div
    id="auth-modal"
    class="hidden fixed inset-0 z-50 flex items-center justify-center p-4"
>
    <!-- Backdrop -->
    <div
        id="auth-backdrop"
        class="absolute inset-0 bg-black/90 backdrop-blur-sm"
    >
    </div>

    <!-- Modal -->
    <div
        class="relative w-full max-w-sm bg-[#0a0a0a] rounded-xl border border-[rgba(255,255,255,0.08)]"
    >
        <!-- Close Button -->
        <button
            id="auth-close"
            class="absolute top-4 right-4 p-1 text-[#666666] hover:text-white transition-colors"
        >
            <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>

        <div class="p-6">
            <!-- Logo -->
            <div class="text-center mb-6">
                <span class="text-sm font-semibold text-white">GenApps</span>
            </div>

            <!-- Tabs -->
            <div class="flex bg-[#111111] rounded-lg p-0.5 mb-5">
                <button
                    id="login-tab"
                    class="flex-1 py-2 text-xs font-medium rounded-md bg-[#1a1a1a] text-white transition-all"
                >
                    Sign In
                </button>
                <button
                    id="register-tab"
                    class="flex-1 py-2 text-xs font-medium rounded-md text-[#666666] hover:text-white transition-all"
                >
                    Sign Up
                </button>
            </div>

            <!-- Login Form -->
            <form id="login-form" class="space-y-3">
                <div>
                    <label class="block text-xs text-[#888888] mb-1.5"
                        >Email</label
                    >
                    <input
                        type="email"
                        name="email"
                        required
                        class="w-full px-3 py-2.5 bg-[#111111] border border-[rgba(255,255,255,0.06)] rounded-lg text-white text-sm focus:outline-none focus:border-[rgba(255,255,255,0.12)]"
                        placeholder="you@example.com"
                    />
                </div>
                <div>
                    <label class="block text-xs text-[#888888] mb-1.5"
                        >Password</label
                    >
                    <input
                        type="password"
                        name="password"
                        required
                        class="w-full px-3 py-2.5 bg-[#111111] border border-[rgba(255,255,255,0.06)] rounded-lg text-white text-sm focus:outline-none focus:border-[rgba(255,255,255,0.12)]"
                        placeholder="••••••••"
                    />
                </div>
                <button
                    type="submit"
                    class="w-full py-2.5 bg-white text-black text-sm font-medium rounded-lg hover:bg-[#e5e5e5] transition-colors"
                >
                    Sign In
                </button>
                <div
                    id="login-error"
                    class="hidden text-red-400 text-xs text-center"
                >
                </div>
            </form>

            <!-- Register Form -->
            <form id="register-form" class="hidden space-y-3">
                <div>
                    <label class="block text-xs text-[#888888] mb-1.5"
                        >Name</label
                    >
                    <input
                        type="text"
                        name="name"
                        required
                        class="w-full px-3 py-2.5 bg-[#111111] border border-[rgba(255,255,255,0.06)] rounded-lg text-white text-sm focus:outline-none focus:border-[rgba(255,255,255,0.12)]"
                        placeholder="John Doe"
                    />
                </div>
                <div>
                    <label class="block text-xs text-[#888888] mb-1.5"
                        >Email</label
                    >
                    <input
                        type="email"
                        name="email"
                        required
                        class="w-full px-3 py-2.5 bg-[#111111] border border-[rgba(255,255,255,0.06)] rounded-lg text-white text-sm focus:outline-none focus:border-[rgba(255,255,255,0.12)]"
                        placeholder="you@example.com"
                    />
                </div>
                <div>
                    <label class="block text-xs text-[#888888] mb-1.5"
                        >Password</label
                    >
                    <input
                        type="password"
                        name="password"
                        required
                        minlength="6"
                        class="w-full px-3 py-2.5 bg-[#111111] border border-[rgba(255,255,255,0.06)] rounded-lg text-white text-sm focus:outline-none focus:border-[rgba(255,255,255,0.12)]"
                        placeholder="••••••••"
                    />
                </div>
                <button
                    type="submit"
                    class="w-full py-2.5 bg-white text-black text-sm font-medium rounded-lg hover:bg-[#e5e5e5] transition-colors"
                >
                    Create Account
                </button>
                <div
                    id="register-error"
                    class="hidden text-red-400 text-xs text-center"
                >
                </div>
            </form>

            <!-- Terms -->
            <p class="text-[10px] text-[#444444] text-center mt-4">
                By continuing, you agree to our <a
                    href="/terms"
                    class="text-[#666666] hover:underline">Terms</a
                > and <a href="/privacy" class="text-[#666666] hover:underline"
                    >Privacy</a
                >
            </p>
        </div>
    </div>
</div>

<script is:inline>
    var API_URL = "http://localhost:3001/api";

    document
        .getElementById("login-tab")
        ?.addEventListener("click", function () {
            this.classList.add("bg-[#1a1a1a]", "text-white");
            this.classList.remove("text-[#666666]");
            document
                .getElementById("register-tab")
                ?.classList.remove("bg-[#1a1a1a]", "text-white");
            document
                .getElementById("register-tab")
                ?.classList.add("text-[#666666]");
            document.getElementById("login-form")?.classList.remove("hidden");
            document.getElementById("register-form")?.classList.add("hidden");
        });

    document
        .getElementById("register-tab")
        ?.addEventListener("click", function () {
            this.classList.add("bg-[#1a1a1a]", "text-white");
            this.classList.remove("text-[#666666]");
            document
                .getElementById("login-tab")
                ?.classList.remove("bg-[#1a1a1a]", "text-white");
            document
                .getElementById("login-tab")
                ?.classList.add("text-[#666666]");
            document
                .getElementById("register-form")
                ?.classList.remove("hidden");
            document.getElementById("login-form")?.classList.add("hidden");
        });

    document
        .getElementById("auth-close")
        ?.addEventListener("click", function () {
            document.getElementById("auth-modal")?.classList.add("hidden");
        });

    document
        .getElementById("auth-backdrop")
        ?.addEventListener("click", function () {
            document.getElementById("auth-modal")?.classList.add("hidden");
        });

    document
        .getElementById("login-form")
        ?.addEventListener("submit", async function (e) {
            e.preventDefault();
            var formData = new FormData(this);
            var errorEl = document.getElementById("login-error");

            try {
                var response = await fetch(API_URL + "/auth/login", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        email: formData.get("email"),
                        password: formData.get("password"),
                    }),
                });
                var data = await response.json();
                if (data.error) {
                    errorEl?.classList.remove("hidden");
                    errorEl.textContent = data.error;
                } else if (data.token) {
                    localStorage.setItem("genapps_token", data.token);
                    localStorage.setItem(
                        "genapps_user",
                        JSON.stringify(data.user),
                    );
                    document
                        .getElementById("auth-modal")
                        ?.classList.add("hidden");
                    window.location.reload();
                }
            } catch (error) {
                errorEl?.classList.remove("hidden");
                errorEl.textContent = "Login failed. Please try again.";
            }
        });

    document
        .getElementById("register-form")
        ?.addEventListener("submit", async function (e) {
            e.preventDefault();
            var formData = new FormData(this);
            var errorEl = document.getElementById("register-error");

            try {
                var response = await fetch(API_URL + "/auth/register", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        name: formData.get("name"),
                        email: formData.get("email"),
                        password: formData.get("password"),
                    }),
                });
                var data = await response.json();
                if (data.error) {
                    errorEl?.classList.remove("hidden");
                    errorEl.textContent = data.error;
                } else if (data.token) {
                    localStorage.setItem("genapps_token", data.token);
                    localStorage.setItem(
                        "genapps_user",
                        JSON.stringify(data.user),
                    );
                    document
                        .getElementById("auth-modal")
                        ?.classList.add("hidden");
                    window.location.reload();
                }
            } catch (error) {
                errorEl?.classList.remove("hidden");
                errorEl.textContent = "Registration failed. Please try again.";
            }
        });
</script>
