---

---

<header class="nav-glass fixed top-0 left-0 right-0 z-50">
  <div class="container-premium">
    <nav class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div
          class="relative w-8 h-8 sm:w-10 sm:h-10 transition-transform duration-300 group-hover:scale-105"
        >
          <img
            src="/logo.png"
            alt="GenApps Logo"
            class="w-full h-full object-contain"
          />
          <div
            class="absolute inset-0 bg-white/20 blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"
          >
          </div>
        </div>
        <span
          class="text-lg sm:text-xl font-display font-bold text-white tracking-tight"
          >GenApps.online</span
        >
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        <a
          href="/templates"
          class="text-sm text-[#a0a0a8] hover:text-white transition-colors"
          >Templates</a
        >
        <a
          href="/pricing"
          class="text-sm text-[#a0a0a8] hover:text-white transition-colors"
          >Pricing</a
        >
        <a
          href="/about"
          class="text-sm text-[#a0a0a8] hover:text-white transition-colors"
          >About</a
        >
        <a
          href="/faq"
          class="text-sm text-[#a0a0a8] hover:text-white transition-colors"
          >FAQ</a
        >
        <a
          href="/contact"
          class="text-sm text-[#a0a0a8] hover:text-white transition-colors"
          >Contact</a
        >
      </div>

      <!-- Right Section -->
      <div class="flex items-center gap-4">
        <!-- Credits Badge -->
        <div
          id="user-credits"
          class="hidden items-center gap-2 px-3 py-1.5 bg-white/5 rounded-lg border border-white/10"
        >
          <span class="text-sm text-[#a0a0a8]" id="credits-count">5</span>
          <span class="text-xs text-[#7a7a82]">credits</span>
        </div>

        <!-- Auth Button -->
        <button
          id="auth-btn"
          class="px-5 py-2 bg-white text-[#0c0c0f] text-sm font-semibold rounded-lg hover:bg-gray-100 transition-all shadow-sm"
        >
          Get Started
        </button>

        <!-- User Menu -->
        <div id="user-menu" class="hidden relative">
          <button id="user-menu-btn" class="flex items-center gap-2">
            <div
              class="w-9 h-9 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white text-sm font-semibold"
              id="user-avatar"
            >
              U
            </div>
          </button>

          <!-- Dropdown -->
          <div
            id="user-dropdown"
            class="hidden absolute right-0 top-full mt-3 w-56 bg-[#18181f] rounded-xl border border-white/10 py-2 shadow-xl animate-scale-in"
          >
            <div class="px-4 py-3 border-b border-white/5">
              <div class="text-sm font-medium text-white" id="dropdown-name">
                User
              </div>
              <div class="text-xs text-[#7a7a82]" id="dropdown-email">
                user@email.com
              </div>
            </div>
            <div class="py-1">
              <a
                href="/builder"
                class="flex items-center gap-3 px-4 py-2.5 text-sm text-[#a0a0a8] hover:text-white hover:bg-white/5 transition-colors"
              >
                <span>⚡</span> Builder
              </a>
              <a
                href="/pricing"
                class="flex items-center gap-3 px-4 py-2.5 text-sm text-[#a0a0a8] hover:text-white hover:bg-white/5 transition-colors"
              >
                <span>💎</span> Upgrade
              </a>
            </div>
            <div class="border-t border-white/5 pt-1">
              <button
                id="logout-btn"
                class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-[#a0a0a8] hover:text-white hover:bg-white/5 transition-colors text-left"
              >
                <span>👋</span> Sign out
              </button>
            </div>
          </div>
        </div>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 text-[#a0a0a8] hover:text-white transition-colors rounded-lg hover:bg-white/5"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-white/5 bg-[#0c0c0f]"
  >
    <div class="container-premium py-4 space-y-1">
      <a
        href="/templates"
        class="block py-3 px-4 text-sm text-[#a0a0a8] hover:text-white hover:bg-white/5 rounded-lg transition-colors"
        >Templates</a
      >
      <a
        href="/pricing"
        class="block py-3 px-4 text-sm text-[#a0a0a8] hover:text-white hover:bg-white/5 rounded-lg transition-colors"
        >Pricing</a
      >
      <a
        href="/about"
        class="block py-3 px-4 text-sm text-[#a0a0a8] hover:text-white hover:bg-white/5 rounded-lg transition-colors"
        >About</a
      >
      <a
        href="/faq"
        class="block py-3 px-4 text-sm text-[#a0a0a8] hover:text-white hover:bg-white/5 rounded-lg transition-colors"
        >FAQ</a
      >
      <a
        href="/contact"
        class="block py-3 px-4 text-sm text-[#a0a0a8] hover:text-white hover:bg-white/5 rounded-lg transition-colors"
        >Contact</a
      >
    </div>
  </div>
</header>

<script is:inline>
  var API_URL = "http://localhost:3001/api";

  function getToken() {
    return localStorage.getItem("genapps_token");
  }

  function getUser() {
    var userData = localStorage.getItem("genapps_user");
    return userData ? JSON.parse(userData) : null;
  }

  function updateUI() {
    var token = getToken();
    var user = getUser();
    var authBtn = document.getElementById("auth-btn");
    var userMenu = document.getElementById("user-menu");
    var userCredits = document.getElementById("user-credits");

    if (token && user) {
      if (authBtn) authBtn.classList.add("hidden");
      if (userMenu) userMenu.classList.remove("hidden");
      if (userCredits) {
        userCredits.classList.remove("hidden");
        userCredits.classList.add("flex");
      }

      var avatar = document.getElementById("user-avatar");
      var dropdownName = document.getElementById("dropdown-name");
      var dropdownEmail = document.getElementById("dropdown-email");
      var creditsCount = document.getElementById("credits-count");

      if (avatar)
        avatar.textContent = user.name
          ? user.name.charAt(0).toUpperCase()
          : "U";
      if (dropdownName) dropdownName.textContent = user.name || "User";
      if (dropdownEmail) dropdownEmail.textContent = user.email || "";
      if (creditsCount)
        creditsCount.textContent =
          user.plan === "free" ? user.credits || 5 : "∞";
    } else {
      if (authBtn) authBtn.classList.remove("hidden");
      if (userMenu) userMenu.classList.add("hidden");
      if (userCredits) userCredits.classList.add("hidden");
    }
  }

  document.getElementById("auth-btn")?.addEventListener("click", function () {
    document.getElementById("auth-modal")?.classList.remove("hidden");
  });

  document
    .getElementById("user-menu-btn")
    ?.addEventListener("click", function () {
      document.getElementById("user-dropdown")?.classList.toggle("hidden");
    });

  document.getElementById("logout-btn")?.addEventListener("click", function () {
    localStorage.removeItem("genapps_token");
    localStorage.removeItem("genapps_user");
    window.location.href = "/";
  });

  document
    .getElementById("mobile-menu-btn")
    ?.addEventListener("click", function () {
      document.getElementById("mobile-menu")?.classList.toggle("hidden");
    });

  document.addEventListener("click", function (e) {
    var userMenu = document.getElementById("user-menu");
    var dropdown = document.getElementById("user-dropdown");
    if (userMenu && !userMenu.contains(e.target)) {
      dropdown?.classList.add("hidden");
    }
  });

  document.addEventListener("DOMContentLoaded", updateUI);
</script>
