---
import { Navigation } from "../components/react/global/Navigation";
import { Footer } from "../components/react/global/Footer";
import "../styles/globals.css";

export interface Props {
  title: string;
  showNav?: boolean;
  showFooter?: boolean;
}

const { title, showNav = true, showFooter = true } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="GenApps.online - Build stunning, production-ready websites with AI in seconds. No coding required."
    />
    <meta name="author" content="MUNEEB UR REHMAN" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title} | GenApps.online</title>
  </head>
  <body class="bg-[#09090b] text-white antialiased min-h-screen flex flex-col">
    {showNav && <Navigation client:load />}
    <main class="flex-grow flex flex-col">
      <slot />
    </main>
    {showFooter && <Footer client:visible />}
  </body>
</html>
