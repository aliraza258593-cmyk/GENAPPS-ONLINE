---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import AuthModal from "../components/AuthModal.astro";

const plans = [
    {
        name: "Free",
        price: "$0",
        period: "forever",
        description: "Perfect for trying out GenApps",
        credits: "5 credits/day",
        features: [
            "5 generations per day",
            "1 AI model (Gemini Flash)",
            "Basic code export",
            "Community support",
            "GenApps watermark",
        ],
        cta: "Get Started Free",
        featured: false,
        href: "/builder",
    },
    {
        name: "Pro",
        price: "$19",
        period: "per month",
        description: "For individual creators and developers",
        credits: "100 credits/month",
        features: [
            "100 generations per month",
            "All 9 AI models",
            "One-click Vercel deploy",
            "GitHub export",
            "No watermark",
            "Priority support",
            "Early access to features",
        ],
        cta: "Start Pro Trial",
        featured: false,
        href: "#",
    },
    {
        name: "Plus",
        price: "$49",
        period: "per month",
        description: "For serious builders and agencies",
        credits: "200 credits/month",
        features: [
            "200 generations per month",
            "All 9 AI models",
            "Deep Thinking mode",
            "One-click Vercel deploy",
            "GitHub integration",
            "Custom domain support",
            "Priority support 24/7",
            "Team sharing (3 seats)",
        ],
        cta: "Start Plus Trial",
        featured: true,
        href: "#",
    },
    {
        name: "Enterprise",
        price: "$199",
        period: "per month",
        description: "For teams and organizations",
        credits: "500 credits/month",
        features: [
            "500 generations per month",
            "All features in Plus",
            "Custom AI fine-tuning",
            "Unlimited team seats",
            "API access",
            "Dedicated account manager",
            "SLA guarantee (99.9%)",
            "Custom integrations",
            "White-label option",
        ],
        cta: "Contact Sales",
        featured: false,
        href: "/contact",
    },
];

const faqs = [
    {
        q: "What is a credit?",
        a: "1 credit = 1 website generation. Each time you generate a website, it uses 1 credit from your monthly allowance.",
    },
    {
        q: "Can I cancel anytime?",
        a: "Yes, cancel with one click. No questions asked. Your credits remain active until the end of your billing period.",
    },
    {
        q: "What payment methods do you accept?",
        a: "We accept all major credit cards, PayPal, and Apple Pay via Paddle. Enterprise customers can pay via invoice.",
    },
    {
        q: "Is there a refund policy?",
        a: "Yes, we offer a 7-day money-back guarantee for Pro and Plus plans. Enterprise plans have custom terms.",
    },
    {
        q: "Can I upgrade or downgrade?",
        a: "Yes, you can change your plan anytime. When upgrading, you'll be charged the prorated difference. When downgrading, the change takes effect at your next billing date.",
    },
];
---

<Layout title="Pricing">
    <Header />
    <AuthModal />

    <main class="pt-16 min-h-screen">
        <div class="container-premium py-16 lg:py-24">
            <!-- Header -->
            <div class="text-center mb-14">
                <div
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 mb-5"
                >
                    <span class="text-sm text-[#a0a0a8]"
                        >Simple, transparent pricing</span
                    >
                </div>
                <h1 class="text-3xl lg:text-4xl font-semibold text-white mb-4">
                    Choose the perfect plan for you
                </h1>
                <p class="text-[#7a7a82] max-w-lg mx-auto">
                    Start free, upgrade when you need more. All plans include
                    our core AI website generation technology.
                </p>
            </div>

            <!-- Pricing Cards -->
            <div
                class="grid md:grid-cols-2 lg:grid-cols-4 gap-5 max-w-6xl mx-auto mb-20"
            >
                {
                    plans.map((plan) => (
                        <div
                            class={`relative p-6 rounded-2xl border transition-all ${plan.featured ? "bg-gradient-to-b from-purple-900/20 to-pink-900/10 border-purple-500/30 shadow-lg shadow-purple-500/10 scale-[1.02]" : "bg-[#121218] border-white/8 hover:border-white/15"}`}
                        >
                            {plan.featured && (
                                <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-gradient-to-r from-purple-500 to-pink-500 text-white text-xs font-semibold rounded-full whitespace-nowrap">
                                    Most Popular
                                </div>
                            )}

                            <div class="mb-5">
                                <h3 class="text-lg font-semibold text-white mb-1">
                                    {plan.name}
                                </h3>
                                <p class="text-xs text-[#7a7a82]">
                                    {plan.description}
                                </p>
                            </div>

                            <div class="mb-2">
                                <span class="text-4xl font-bold text-white">
                                    {plan.price}
                                </span>
                                <span class="text-[#7a7a82] text-sm ml-1">
                                    /{plan.period}
                                </span>
                            </div>

                            <div class="mb-5">
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-purple-500/10 text-purple-300 text-xs font-medium rounded-full">
                                    <svg
                                        class="w-3 h-3"
                                        fill="currentColor"
                                        viewBox="0 0 20 20"
                                    >
                                        <path d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" />
                                    </svg>
                                    {plan.credits}
                                </span>
                            </div>

                            <ul class="space-y-2.5 mb-6">
                                {plan.features.map((feature) => (
                                    <li class="flex items-start gap-2.5 text-sm text-[#a0a0a8]">
                                        <svg
                                            class="w-4 h-4 text-green-400 flex-shrink-0 mt-0.5"
                                            fill="currentColor"
                                            viewBox="0 0 20 20"
                                        >
                                            <path
                                                fill-rule="evenodd"
                                                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                                clip-rule="evenodd"
                                            />
                                        </svg>
                                        <span>{feature}</span>
                                    </li>
                                ))}
                            </ul>

                            <a
                                href={plan.href}
                                class={`block w-full py-3 rounded-xl font-semibold text-center transition-all text-sm ${plan.featured ? "bg-white text-[#0c0c0f] hover:bg-gray-100 shadow-lg shadow-white/10" : "bg-white/5 text-white hover:bg-white/10 border border-white/10"}`}
                            >
                                {plan.cta}
                            </a>
                        </div>
                    ))
                }
            </div>

            <!-- Comparison Table -->
            <div class="max-w-4xl mx-auto mb-20">
                <h2 class="text-xl font-semibold text-white mb-6 text-center">
                    Compare Plans
                </h2>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-white/10">
                                <th
                                    class="text-left py-4 px-4 text-[#7a7a82] font-medium"
                                    >Feature</th
                                >
                                <th
                                    class="text-center py-4 px-4 text-white font-medium"
                                    >Free</th
                                >
                                <th
                                    class="text-center py-4 px-4 text-white font-medium"
                                    >Pro</th
                                >
                                <th
                                    class="text-center py-4 px-4 text-purple-400 font-medium"
                                    >Plus</th
                                >
                                <th
                                    class="text-center py-4 px-4 text-white font-medium"
                                    >Enterprise</th
                                >
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5">
                            <tr>
                                <td class="py-3 px-4 text-[#a0a0a8]"
                                    >Monthly Credits</td
                                >
                                <td class="py-3 px-4 text-center text-white"
                                    >5/day</td
                                >
                                <td class="py-3 px-4 text-center text-white"
                                    >100</td
                                >
                                <td
                                    class="py-3 px-4 text-center text-purple-300"
                                    >200</td
                                >
                                <td class="py-3 px-4 text-center text-white"
                                    >500</td
                                >
                            </tr>
                            <tr>
                                <td class="py-3 px-4 text-[#a0a0a8]"
                                    >AI Models</td
                                >
                                <td class="py-3 px-4 text-center text-white"
                                    >1</td
                                >
                                <td class="py-3 px-4 text-center text-white"
                                    >9</td
                                >
                                <td
                                    class="py-3 px-4 text-center text-purple-300"
                                    >9</td
                                >
                                <td class="py-3 px-4 text-center text-white"
                                    >9 + Custom</td
                                >
                            </tr>
                            <tr>
                                <td class="py-3 px-4 text-[#a0a0a8]"
                                    >Deep Thinking Mode</td
                                >
                                <td class="py-3 px-4 text-center text-[#55555d]"
                                    >—</td
                                >
                                <td class="py-3 px-4 text-center text-[#55555d]"
                                    >—</td
                                >
                                <td class="py-3 px-4 text-center text-green-400"
                                    >✓</td
                                >
                                <td class="py-3 px-4 text-center text-green-400"
                                    >✓</td
                                >
                            </tr>
                            <tr>
                                <td class="py-3 px-4 text-[#a0a0a8]"
                                    >Vercel Deploy</td
                                >
                                <td class="py-3 px-4 text-center text-[#55555d]"
                                    >—</td
                                >
                                <td class="py-3 px-4 text-center text-green-400"
                                    >✓</td
                                >
                                <td class="py-3 px-4 text-center text-green-400"
                                    >✓</td
                                >
                                <td class="py-3 px-4 text-center text-green-400"
                                    >✓</td
                                >
                            </tr>
                            <tr>
                                <td class="py-3 px-4 text-[#a0a0a8]"
                                    >GitHub Export</td
                                >
                                <td class="py-3 px-4 text-center text-[#55555d]"
                                    >—</td
                                >
                                <td class="py-3 px-4 text-center text-green-400"
                                    >✓</td
                                >
                                <td class="py-3 px-4 text-center text-green-400"
                                    >✓</td
                                >
                                <td class="py-3 px-4 text-center text-green-400"
                                    >✓</td
                                >
                            </tr>
                            <tr>
                                <td class="py-3 px-4 text-[#a0a0a8]"
                                    >Team Seats</td
                                >
                                <td class="py-3 px-4 text-center text-white"
                                    >1</td
                                >
                                <td class="py-3 px-4 text-center text-white"
                                    >1</td
                                >
                                <td
                                    class="py-3 px-4 text-center text-purple-300"
                                    >3</td
                                >
                                <td class="py-3 px-4 text-center text-white"
                                    >Unlimited</td
                                >
                            </tr>
                            <tr>
                                <td class="py-3 px-4 text-[#a0a0a8]"
                                    >API Access</td
                                >
                                <td class="py-3 px-4 text-center text-[#55555d]"
                                    >—</td
                                >
                                <td class="py-3 px-4 text-center text-[#55555d]"
                                    >—</td
                                >
                                <td class="py-3 px-4 text-center text-[#55555d]"
                                    >—</td
                                >
                                <td class="py-3 px-4 text-center text-green-400"
                                    >✓</td
                                >
                            </tr>
                            <tr>
                                <td class="py-3 px-4 text-[#a0a0a8]">Support</td
                                >
                                <td class="py-3 px-4 text-center text-white"
                                    >Community</td
                                >
                                <td class="py-3 px-4 text-center text-white"
                                    >Priority</td
                                >
                                <td
                                    class="py-3 px-4 text-center text-purple-300"
                                    >24/7</td
                                >
                                <td class="py-3 px-4 text-center text-white"
                                    >Dedicated</td
                                >
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- FAQ Section -->
            <div class="max-w-2xl mx-auto">
                <h2 class="text-xl font-semibold text-white mb-6 text-center">
                    Frequently Asked Questions
                </h2>
                <div class="space-y-3">
                    {
                        faqs.map((faq, index) => (
                            <div
                                class="faq-item p-5 bg-[#121218] border border-white/8 rounded-xl cursor-pointer hover:border-white/15 transition-all"
                                data-index={index}
                            >
                                <div class="flex items-center justify-between">
                                    <div class="text-sm font-medium text-white">
                                        {faq.q}
                                    </div>
                                    <svg
                                        class="faq-icon w-4 h-4 text-[#7a7a82] transition-transform"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"
                                        />
                                    </svg>
                                </div>
                                <div class="faq-answer hidden mt-3 text-sm text-[#7a7a82]">
                                    {faq.a}
                                </div>
                            </div>
                        ))
                    }
                </div>
                <p class="text-center text-sm text-[#7a7a82] mt-8">
                    More questions? <a
                        href="/faq"
                        class="text-white hover:underline">Visit our FAQ</a
                    > or <a href="/contact" class="text-white hover:underline"
                        >contact us</a
                    >
                </p>
            </div>
        </div>
    </main>

    <Footer />
</Layout>

<script is:inline>
    document.querySelectorAll(".faq-item").forEach((item) => {
        item.addEventListener("click", function () {
            const answer = this.querySelector(".faq-answer");
            const icon = this.querySelector(".faq-icon");

            // Close all others
            document.querySelectorAll(".faq-item").forEach((other) => {
                if (other !== this) {
                    other.querySelector(".faq-answer")?.classList.add("hidden");
                    other
                        .querySelector(".faq-icon")
                        ?.classList.remove("rotate-180");
                }
            });

            // Toggle current
            answer?.classList.toggle("hidden");
            icon?.classList.toggle("rotate-180");
        });
    });
</script>
