---
import Layout from "../layouts/Layout.astro";
import { Check, X, Zap } from "lucide-react";
import { Button } from "../components/react/global/Button";
---

<Layout title="Pricing">
    <div class="relative min-h-screen py-24 overflow-hidden">
        {/* Background Elements */}
        <div class="absolute inset-0 pointer-events-none">
            <div
                class="absolute top-[20%] right-[20%] w-[500px] h-[500px] bg-violet-600/10 rounded-full blur-[100px]"
            >
            </div>
            <div
                class="absolute bottom-[20%] left-[20%] w-[500px] h-[500px] bg-cyan-500/10 rounded-full blur-[100px]"
            >
            </div>
        </div>

        <div class="container mx-auto px-4 relative z-10">
            <div class="text-center max-w-3xl mx-auto mb-20 scroll-mt-20">
                <h1 class="text-4xl md:text-6xl font-bold mb-6 tracking-tight">
                    Simple, Transparent <span class="text-violet-400"
                        >Pricing</span
                    >
                </h1>
                <p class="text-xl text-gray-400">
                    Start building for free. Upgrade as you scale.
                </p>
            </div>

            <div
                class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-7xl mx-auto"
            >
                {/* Starter Plan */}
                <div
                    class="rounded-3xl p-8 bg-[#18181b]/50 backdrop-blur-sm border border-white/5 flex flex-col hover:border-white/10 transition-colors"
                >
                    <h3 class="text-lg font-medium text-gray-400 mb-2">
                        Starter
                    </h3>
                    <div class="flex items-baseline gap-1 mb-6">
                        <span class="text-4xl font-bold text-white">$0</span>
                        <span class="text-gray-500">/mo</span>
                    </div>
                    <p class="text-gray-400 text-sm mb-8 h-10">
                        Perfect for experimenting and generating ideas.
                    </p>
                    <Button variant="secondary" className="w-full mb-8"
                        >Get Started</Button
                    >
                    <ul class="space-y-4 text-gray-300 text-sm flex-1">
                        <li class="flex items-center gap-3">
                            <Check
                                className="w-4 h-4 text-green-400 shrink-0"
                            /> Unlimited Live Previews
                        </li>
                        <li class="flex items-center gap-3">
                            <Check
                                className="w-4 h-4 text-green-400 shrink-0"
                            /> Access to Gemini 1.5 Flash
                        </li>
                        <li class="flex items-center gap-3">
                            <Check
                                className="w-4 h-4 text-green-400 shrink-0"
                            /> Public Projects
                        </li>
                        <li class="flex items-center gap-3 text-gray-600">
                            <X className="w-4 h-4 shrink-0" /> No Code Export
                        </li>
                        <li class="flex items-center gap-3 text-gray-600">
                            <X className="w-4 h-4 shrink-0" /> No GitHub Sync
                        </li>
                    </ul>
                </div>

                {/* Plus Plan (Highlighted) */}
                <div
                    class="relative rounded-3xl p-8 bg-[#1c1c20] border-2 border-violet-500 flex flex-col shadow-2xl shadow-violet-500/10 scale-105 z-10"
                >
                    <div
                        class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-violet-500 text-white px-3 py-1 rounded-full text-xs font-semibold tracking-wide uppercase"
                    >
                        Most Popular
                    </div>
                    <h3 class="text-lg font-medium text-violet-400 mb-2">
                        Plus
                    </h3>
                    <div class="flex items-baseline gap-1 mb-6">
                        <span class="text-4xl font-bold text-white">$19</span>
                        <span class="text-gray-500">/mo</span>
                    </div>
                    <p class="text-gray-400 text-sm mb-8 h-10">
                        For developers and creators who need code access.
                    </p>
                    <Button
                        variant="primary"
                        className="w-full mb-8 shadow-lg shadow-violet-500/25"
                        >Upgrade to Plus</Button
                    >
                    <ul class="space-y-4 text-gray-300 text-sm flex-1">
                        <li class="flex items-center gap-3">
                            <Check
                                className="w-4 h-4 text-violet-400 shrink-0"
                            /> Everything in Starter
                        </li>
                        <li class="flex items-center gap-3">
                            <Check
                                className="w-4 h-4 text-violet-400 shrink-0"
                            />
                            <span class="text-white font-medium"
                                >Code View & Edit</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <Check
                                className="w-4 h-4 text-violet-400 shrink-0"
                            /> Download Source Code
                        </li>
                        <li class="flex items-center gap-3">
                            <Check
                                className="w-4 h-4 text-violet-400 shrink-0"
                            /> 500 Fast Generations/mo
                        </li>
                        <li class="flex items-center gap-3">
                            <Check
                                className="w-4 h-4 text-violet-400 shrink-0"
                            /> Private Projects
                        </li>
                    </ul>
                </div>

                {/* Business Plan */}
                <div
                    class="rounded-3xl p-8 bg-[#18181b]/50 backdrop-blur-sm border border-white/5 flex flex-col hover:border-white/10 transition-colors"
                >
                    <h3 class="text-lg font-medium text-cyan-400 mb-2">
                        Business
                    </h3>
                    <div class="flex items-baseline gap-1 mb-6">
                        <span class="text-4xl font-bold text-white">$49</span>
                        <span class="text-gray-500">/mo</span>
                    </div>
                    <p class="text-gray-400 text-sm mb-8 h-10">
                        For teams building products at scale.
                    </p>
                    <Button variant="secondary" className="w-full mb-8"
                        >Contact Sales</Button
                    >
                    <ul class="space-y-4 text-gray-300 text-sm flex-1">
                        <li class="flex items-center gap-3">
                            <Check className="w-4 h-4 text-cyan-400 shrink-0" /> Everything
                            in Plus
                        </li>
                        <li class="flex items-center gap-3">
                            <Check className="w-4 h-4 text-cyan-400 shrink-0" /> GitHub
                            & Vercel Sync
                        </li>
                        <li class="flex items-center gap-3">
                            <Check className="w-4 h-4 text-cyan-400 shrink-0" /> Priority
                            Support
                        </li>
                        <li class="flex items-center gap-3">
                            <Check className="w-4 h-4 text-cyan-400 shrink-0" /> Custom
                            Models (GPT-4)
                        </li>
                        <li class="flex items-center gap-3">
                            <Check className="w-4 h-4 text-cyan-400 shrink-0" /> Team
                            Collaboration
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</Layout>
