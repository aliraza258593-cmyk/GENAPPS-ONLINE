---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="About">
    <Header />

    <main class="pt-14 min-h-screen">
        <div class="container-premium py-16 lg:py-24">
            <div class="max-w-2xl mx-auto">
                <div class="text-center mb-12">
                    <h1
                        class="text-2xl lg:text-3xl font-semibold text-white mb-3"
                    >
                        About GenApps
                    </h1>
                    <p class="text-sm text-[#666666]">
                        Building the future of web development
                    </p>
                </div>

                <div class="space-y-8 text-sm text-[#888888] leading-relaxed">
                    <section>
                        <h2 class="text-white font-medium mb-3">Our Mission</h2>
                        <p>
                            GenApps.online empowers anyone to build beautiful,
                            production-ready websites in seconds using the power
                            of AI. We believe that great web design shouldn't
                            require years of coding experience.
                        </p>
                    </section>

                    <section>
                        <h2 class="text-white font-medium mb-3">What We Do</h2>
                        <p>
                            Our AI-powered platform takes your natural language
                            descriptions and transforms them into clean, modern
                            React + Tailwind CSS code. Whether you're a startup
                            founder, designer, or developer, GenApps helps you
                            bring your ideas to life faster than ever.
                        </p>
                    </section>

                    <section>
                        <h2 class="text-white font-medium mb-3">
                            Our Technology
                        </h2>
                        <p>
                            We leverage the most advanced AI models including
                            GPT-5.2, Claude 4.5, Gemini, and more to generate
                            high-quality, responsive websites. Our system is
                            trained on thousands of modern web designs to ensure
                            your output looks professional and follows best
                            practices.
                        </p>
                    </section>

                    <section>
                        <h2 class="text-white font-medium mb-3">
                            Built for Everyone
                        </h2>
                        <ul class="space-y-2">
                            <li class="flex items-start gap-2">
                                <span class="text-[#666666]">•</span>
                                <span
                                    ><strong class="text-white">Founders</strong
                                    > — Launch landing pages in minutes, not weeks</span
                                >
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="text-[#666666]">•</span>
                                <span
                                    ><strong class="text-white"
                                        >Designers</strong
                                    > — Rapidly prototype and iterate on concepts</span
                                >
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="text-[#666666]">•</span>
                                <span
                                    ><strong class="text-white"
                                        >Developers</strong
                                    > — Skip the boilerplate and focus on what matters</span
                                >
                            </li>
                        </ul>
                    </section>

                    <section
                        class="p-5 bg-[#0a0a0a] border border-[rgba(255,255,255,0.06)] rounded-xl"
                    >
                        <h2 class="text-white font-medium mb-2">
                            Get in Touch
                        </h2>
                        <p class="mb-3">
                            Have questions or feedback? We'd love to hear from
                            you.
                        </p>
                        <a
                            href="/contact"
                            class="inline-flex items-center gap-2 text-white hover:underline"
                        >
                            Contact Us
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                            </svg>
                        </a>
                    </section>
                </div>
            </div>
        </div>
    </main>

    <Footer />
</Layout>
