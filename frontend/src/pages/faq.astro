---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const faqs = [
    {
        q: "What is GenApps.online?",
        a: "GenApps.online is an AI-powered platform that generates production-ready React websites from natural language descriptions.",
    },
    {
        q: "How does it work?",
        a: "Describe your website, select an AI model, and our system generates complete React + Tailwind CSS code in seconds.",
    },
    {
        q: "Can I edit the generated code?",
        a: "Yes, you own all generated code. Export it and modify as needed.",
    },
    {
        q: "What AI models are available?",
        a: "We offer 9 AI models including GPT-5.2, Claude 4.5, Gemini and more.",
    },
    {
        q: "How many websites can I generate?",
        a: "Free users get 5 generations per day. Pro subscribers get unlimited.",
    },
    {
        q: "Is there a refund policy?",
        a: "Yes, we offer a 7-day money-back guarantee for new Pro subscriptions.",
    },
];
---

<Layout title="FAQ">
    <Header />

    <main class="pt-14 min-h-screen">
        <div class="container-premium py-16 lg:py-24">
            <div class="text-center mb-12">
                <h1 class="text-2xl lg:text-3xl font-semibold text-white mb-3">
                    FAQ
                </h1>
                <p class="text-sm text-[#666666]">
                    Answers to common questions
                </p>
            </div>

            <div class="max-w-2xl mx-auto space-y-3">
                {
                    faqs.map((faq) => (
                        <div class="p-5 bg-[#0a0a0a] border border-[rgba(255,255,255,0.06)] rounded-xl">
                            <div class="text-sm text-white mb-2">{faq.q}</div>
                            <div class="text-xs text-[#666666] leading-relaxed">
                                {faq.a}
                            </div>
                        </div>
                    ))
                }
            </div>

            <div class="text-center mt-12">
                <p class="text-xs text-[#666666] mb-4">Still have questions?</p>
                <a
                    href="/contact"
                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-black text-sm font-medium rounded-lg hover:bg-[#e5e5e5] transition-colors"
                >
                    Contact Support
                </a>
            </div>
        </div>
    </main>

    <Footer />
</Layout>
