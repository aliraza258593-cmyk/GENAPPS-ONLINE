---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import AuthModal from "../components/AuthModal.astro";

const testimonials = [
    {
        text: "I was able to build this web app I've been trying to build for the last year. It has everything I need. I tried them all Bolt, Lovable, Replit, V0... but GenApps actually did it!",
        name: "Alex Thompson",
        title: "Founder, TechStart",
        platform: "LinkedIn",
    },
    {
        text: "The builder is really cool. I have gotten further in 5 days than I have in a year.",
        name: "Chris R. Pettigrew, Sr",
        title: "President, Inteliese LLC",
        platform: "Email",
    },
    {
        text: "Generated a full-featured dashboard in less than 25 minutes. Would have taken a team weeks.",
        name: "Haroon Hameed",
        title: "MD, MBA Candidate",
        platform: "Twitter",
    },
    {
        text: "Finally, an AI builder that actually understands what I want. The code quality is production-ready.",
        name: "Sarah Chen",
        title: "Product Designer",
        platform: "Twitter",
    },
    {
        text: "I built my entire SaaS landing page in 20 minutes. The export to Vercel feature is game-changing.",
        name: "Marcus Johnson",
        title: "Indie Hacker",
        platform: "Twitter",
    },
    {
        text: "Been using GenApps for all my client work. Saves me hours on every project.",
        name: "Emily Rodriguez",
        title: "Freelance Developer",
        platform: "Email",
    },
];

const stats = [
    { value: "50,000+", label: "Websites Generated" },
    { value: "10,000+", label: "Happy Developers" },
    { value: "9", label: "AI Models" },
    { value: "30s", label: "Avg. Generation Time" },
];
---

<Layout title="AI Website Builder">
    <Header />
    <AuthModal />

    <main class="pt-16">
        <!-- Hero Section -->
        <section
            class="relative min-h-[90vh] flex items-center overflow-hidden"
        >
            <!-- Animated gradient background -->
            <div
                class="absolute inset-0 bg-gradient-to-br from-purple-900/20 via-transparent to-pink-900/10"
            >
            </div>
            <div
                class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[600px] bg-purple-500/10 rounded-full blur-[150px] pointer-events-none"
            >
            </div>
            <div
                class="absolute bottom-0 right-0 w-[600px] h-[400px] bg-pink-500/10 rounded-full blur-[120px] pointer-events-none"
            >
            </div>

            <div class="relative container-premium py-20 lg:py-28">
                <div class="text-center max-w-4xl mx-auto">
                    <!-- Badge -->
                    <div
                        class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gradient-to-r from-purple-500/10 to-pink-500/10 border border-purple-500/20 mb-8 animate-fade-in-up"
                    >
                        <div class="pulse-dot"></div>
                        <span class="text-sm text-purple-300"
                            >AI-Powered Full-Stack Website Builder</span
                        >
                    </div>

                    <!-- Main Heading -->
                    <h1
                        class="font-display text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold tracking-tight leading-[1.1] mb-6 animate-fade-in-up"
                        style="animation-delay: 0.1s;"
                    >
                        <span class="text-white">Don't just think it</span><br
                        />
                        <span
                            class="bg-gradient-to-r from-purple-400 via-pink-400 to-purple-400 bg-clip-text text-transparent"
                            >Build</span
                        >
                        <span class="text-white"> it</span>
                    </h1>

                    <!-- Subheading -->
                    <p
                        class="text-lg lg:text-xl text-[#a0a0a8] max-w-2xl mx-auto mb-10 leading-relaxed animate-fade-in-up"
                        style="animation-delay: 0.2s;"
                    >
                        Generate stunning, <strong class="text-white"
                            >production-ready full-stack websites</strong
                        > in seconds. Complete with working navigation, forms, animations,
                        and responsive design.
                    </p>

                    <!-- Main CTA Box -->
                    <div
                        class="max-w-2xl mx-auto mb-10 animate-fade-in-up"
                        style="animation-delay: 0.3s;"
                    >
                        <div
                            class="bg-[#121218]/80 backdrop-blur-xl border border-white/10 rounded-2xl p-3 shadow-2xl shadow-purple-500/5"
                        >
                            <div class="relative">
                                <input
                                    type="text"
                                    id="hero-prompt"
                                    class="w-full px-5 py-4 bg-[#18181f] border border-white/5 rounded-xl text-white text-base placeholder-[#55555d] focus:outline-none focus:border-purple-500/30 focus:ring-2 focus:ring-purple-500/10 transition-all"
                                    placeholder="Describe your website... e.g., A modern SaaS landing page with pricing"
                                />
                                <button
                                    id="hero-generate-btn"
                                    class="absolute right-2 top-1/2 -translate-y-1/2 px-6 py-2.5 bg-gradient-to-r from-purple-600 to-pink-600 text-white text-sm font-semibold rounded-lg hover:from-purple-500 hover:to-pink-500 transition-all shadow-lg shadow-purple-500/25"
                                >
                                    Generate →
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Trust Badges -->
                    <div
                        class="flex flex-wrap items-center justify-center gap-6 text-sm animate-fade-in-up"
                        style="animation-delay: 0.4s;"
                    >
                        <div class="flex items-center gap-2 text-[#7a7a82]">
                            <svg
                                class="w-4 h-4 text-green-400"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            <span>No credit card required</span>
                        </div>
                        <div class="flex items-center gap-2 text-[#7a7a82]">
                            <svg
                                class="w-4 h-4 text-green-400"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            <span>5 free builds per day</span>
                        </div>
                        <div class="flex items-center gap-2 text-[#7a7a82]">
                            <svg
                                class="w-4 h-4 text-green-400"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            <span>Deploy to Vercel instantly</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Stats Section -->
        <section class="py-16 border-t border-white/5">
            <div class="container-premium">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
                    {
                        stats.map((stat) => (
                            <div class="text-center">
                                <div class="text-3xl lg:text-4xl font-bold text-white mb-1">
                                    {stat.value}
                                </div>
                                <div class="text-sm text-[#7a7a82]">
                                    {stat.label}
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- Templates Section -->
        <section class="py-24 border-t border-white/5">
            <div class="container-premium">
                <div class="text-center mb-12">
                    <h2 class="text-2xl lg:text-3xl font-bold text-white mb-4">
                        Start with a template or go custom
                    </h2>
                    <p class="text-[#7a7a82] max-w-lg mx-auto">
                        Choose a starting point or describe exactly what you
                        need. Our AI handles the rest.
                    </p>
                </div>

                <!-- Template Grid -->
                <div
                    class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4"
