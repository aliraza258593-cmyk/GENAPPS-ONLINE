                        testimonials.map((t) => (
                            <div class="flex-shrink-0 w-[380px] p-6 bg-[#121218] border border-white/8 rounded-2xl">
                                <div class="flex gap-1 text-yellow-400 mb-4">
                                    ★★★★★
                                </div>
                                <p class="text-sm text-[#a0a0a8] leading-relaxed mb-5">
                                    "{t.text}"
