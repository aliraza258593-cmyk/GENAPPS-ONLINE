                            More Templates
                        </p>
                        <p class="text-xs text-[#55555d]">
                            Explore 50+ templates
                        </p>
                    </a>
                </div>
            </div>
        </section>

        <!-- Features Section -->
        <section class="py-24 border-t border-white/5">
            <div class="container-premium">
                <div class="text-center mb-16">
                    <div
                        class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-purple-500/10 border border-purple-500/20 text-purple-300 text-xs font-medium mb-4"
                    >
                        Why GenApps?
                    </div>
                    <h2 class="text-2xl lg:text-3xl font-bold text-white mb-4">
                        Everything You Need, Built-In
                    </h2>
                    <p class="text-[#7a7a82] max-w-lg mx-auto">
                        Powerful features to help you build and ship full-stack
