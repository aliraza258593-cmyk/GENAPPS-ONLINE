                    <a href="/builder?template=portfolio" class="group block">
                        <div
                            class="aspect-[4/3] bg-gradient-to-br from-pink-900/20 to-orange-900/10 rounded-xl border border-white/8 overflow-hidden mb-3 transition-all group-hover:border-pink-500/30 group-hover:shadow-lg group-hover:shadow-pink-500/10"
                        >
                            <div
                                class="w-full h-full flex items-center justify-center text-4xl group-hover:scale-110 transition-transform"
                            >
                                🎨
                            </div>
                        </div>
                        <p
                            class="text-sm text-[#a0a0a8] group-hover:text-white transition-colors font-medium"
                        >
                            Portfolio
                        </p>
                        <p class="text-xs text-[#55555d]">
                            Showcase your work beautifully
                        </p>
                    </a>
                    <a href="/builder?template=dashboard" class="group block">
                        <div
                            class="aspect-[4/3] bg-gradient-to-br from-green-900/20 to-emerald-900/10 rounded-xl border border-white/8 overflow-hidden mb-3 transition-all group-hover:border-green-500/30 group-hover:shadow-lg group-hover:shadow-green-500/10"
                        >
                            <div
                                class="w-full h-full flex items-center justify-center text-4xl group-hover:scale-110 transition-transform"
                            >
                                📊
                            </div>
                        </div>
                        <p
                            class="text-sm text-[#a0a0a8] group-hover:text-white transition-colors font-medium"
                        >
                            Admin Dashboard
                        </p>
                        <p class="text-xs text-[#55555d]">
                            Charts, tables, sidebar nav
                        </p>
                    </a>
                    <a href="/builder?template=blog" class="group block">
                        <div
                            class="aspect-[4/3] bg-gradient-to-br from-yellow-900/20 to-amber-900/10 rounded-xl border border-white/8 overflow-hidden mb-3 transition-all group-hover:border-yellow-500/30 group-hover:shadow-lg group-hover:shadow-yellow-500/10"
                        >
                            <div
                                class="w-full h-full flex items-center justify-center text-4xl group-hover:scale-110 transition-transform"
                            >
                                📝
                            </div>
                        </div>
                        <p
                            class="text-sm text-[#a0a0a8] group-hover:text-white transition-colors font-medium"
                        >
                            Blog & Magazine
                        </p>
                        <p class="text-xs text-[#55555d]">
                            Article layouts & categories
                        </p>
                    </a>
                    <a href="/builder?template=restaurant" class="group block">
                        <div
                            class="aspect-[4/3] bg-gradient-to-br from-red-900/20 to-orange-900/10 rounded-xl border border-white/8 overflow-hidden mb-3 transition-all group-hover:border-red-500/30 group-hover:shadow-lg group-hover:shadow-red-500/10"
                        >
                            <div
                                class="w-full h-full flex items-center justify-center text-4xl group-hover:scale-110 transition-transform"
                            >
                                🍕
                            </div>
                        </div>
                        <p
                            class="text-sm text-[#a0a0a8] group-hover:text-white transition-colors font-medium"
                        >
                            Restaurant
                        </p>
                        <p class="text-xs text-[#55555d]">
                            Menu, reservations, gallery
                        </p>
                    </a>
                    <a href="/builder?template=agency" class="group block">
                        <div
                            class="aspect-[4/3] bg-gradient-to-br from-indigo-900/20 to-violet-900/10 rounded-xl border border-white/8 overflow-hidden mb-3 transition-all group-hover:border-indigo-500/30 group-hover:shadow-lg group-hover:shadow-indigo-500/10"
                        >
                            <div
                                class="w-full h-full flex items-center justify-center text-4xl group-hover:scale-110 transition-transform"
                            >
                                🏢
                            </div>
                        </div>
                        <p
                            class="text-sm text-[#a0a0a8] group-hover:text-white transition-colors font-medium"
                        >
                            Agency
                        </p>
                        <p class="text-xs text-[#55555d]">
                            Services, case studies, team
                        </p>
                    </a>
                    <a href="/templates" class="group block">
                        <div
                            class="aspect-[4/3] bg-[#121218] rounded-xl border border-white/8 overflow-hidden mb-3 transition-all group-hover:border-white/20 flex items-center justify-center"
                        >
                            <div class="text-center">
                                <div
                                    class="text-2xl text-[#7a7a82] group-hover:text-white mb-1"
                                >
                                    →
                                </div>
                                <div
                                    class="text-xs text-[#55555d] group-hover:text-[#a0a0a8]"
                                >
                                    View All
                                </div>
                            </div>
                        </div>
                        <p
                            class="text-sm text-[#a0a0a8] group-hover:text-white transition-colors font-medium"
