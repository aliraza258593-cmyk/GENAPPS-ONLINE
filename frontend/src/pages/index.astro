                            <div
                                class="w-full h-full flex items-center justify-center text-4xl group-hover:scale-110 transition-transform"
                            >
                                🛒
                            </div>
                        </div>
                        <p
                            class="text-sm text-[#a0a0a8] group-hover:text-white transition-colors font-medium"
                        >
                            E-commerce Store
                        </p>
                        <p class="text-xs text-[#55555d]">
                            Full-stack with cart & checkout
                        </p>
                    </a>
                    <a href="/builder?template=saas" class="group block">
                        <div
                            class="aspect-[4/3] bg-gradient-to-br from-blue-900/20 to-cyan-900/10 rounded-xl border border-white/8 overflow-hidden mb-3 transition-all group-hover:border-blue-500/30 group-hover:shadow-lg group-hover:shadow-blue-500/10"
                        >
                            <div
                                class="w-full h-full flex items-center justify-center text-4xl group-hover:scale-110 transition-transform"
                            >
                                🚀
                            </div>
                        </div>
                        <p
                            class="text-sm text-[#a0a0a8] group-hover:text-white transition-colors font-medium"
                        >
                            SaaS Landing
                        </p>
                        <p class="text-xs text-[#55555d]">
                            Hero, features, pricing, FAQ
