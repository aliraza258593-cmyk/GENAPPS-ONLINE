---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Terms of Service">
    <Header />

    <main class="pt-14 min-h-screen">
        <div class="container-premium py-16 lg:py-24">
            <div class="max-w-2xl mx-auto">
                <h1 class="text-2xl font-semibold text-white mb-2">
                    Terms of Service
                </h1>
                <p class="text-xs text-[#666666] mb-8">
                    Last updated: January 2024
                </p>

                <div class="space-y-6 text-sm text-[#888888] leading-relaxed">
                    <section>
                        <h2 class="text-white font-medium mb-2">
                            1. Agreement to Terms
                        </h2>
                        <p>
                            By accessing GenApps.online, operated by MUNEEB UR
                            REHMAN, you agree to these Terms of Service.
                        </p>
                    </section>
                    <section>
                        <h2 class="text-white font-medium mb-2">
                            2. Description of Service
                        </h2>
                        <p>
                            GenApps.online provides AI-powered website
                            generation. Users can generate React/Tailwind CSS
                            code from natural language descriptions.
                        </p>
                    </section>
                    <section>
                        <h2 class="text-white font-medium mb-2">
                            3. User Accounts
                        </h2>
                        <p>
                            You are responsible for maintaining the security of
                            your account and all activities under your account.
                        </p>
                    </section>
                    <section>
                        <h2 class="text-white font-medium mb-2">
                            4. Intellectual Property
                        </h2>
                        <p>
                            You retain ownership of code generated through our
                            service. The GenApps.online platform and its content
                            remain our property.
                        </p>
                    </section>
                    <section>
                        <h2 class="text-white font-medium mb-2">
                            5. Acceptable Use
                        </h2>
                        <p>
                            You agree not to use the service to generate
                            illegal, harmful, or infringing content.
                        </p>
                    </section>
                    <section>
                        <h2 class="text-white font-medium mb-2">
                            6. Payment Terms
                        </h2>
                        <p>
                            Subscription fees are billed through Paddle. By
                            subscribing, you authorize recurring charges.
                        </p>
                    </section>
                    <section>
                        <h2 class="text-white font-medium mb-2">
                            7. Limitation of Liability
                        </h2>
                        <p>
                            GenApps.online is provided "as is" without
                            warranties. We are not liable for any damages from
                            use of the service.
                        </p>
                    </section>
                    <section>
                        <h2 class="text-white font-medium mb-2">8. Contact</h2>
                        <p>For questions, contact support@genapps.online</p>
                    </section>
                </div>
            </div>
        </div>
    </main>

    <Footer />
</Layout>
