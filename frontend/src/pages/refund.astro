---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Refund Policy">
    <Header />

    <main class="pt-14 min-h-screen">
        <div class="container-premium py-16 lg:py-24">
            <div class="max-w-2xl mx-auto">
                <h1 class="text-2xl font-semibold text-white mb-2">
                    Refund Policy
                </h1>
                <p class="text-xs text-[#666666] mb-8">
                    Last updated: January 2024
                </p>

                <div
                    class="p-4 bg-[#0a0a0a] border border-[rgba(255,255,255,0.06)] rounded-xl mb-8"
                >
                    <div class="flex items-center gap-2 mb-2">
                        <span class="text-green-400">✓</span>
                        <span class="text-sm font-medium text-white"
                            >7-Day Money-Back Guarantee</span
                        >
                    </div>
                    <p class="text-xs text-[#666666]">
                        Not satisfied? Get a full refund within 7 days.
                    </p>
                </div>

                <div class="space-y-6 text-sm text-[#888888] leading-relaxed">
                    <section>
                        <h2 class="text-white font-medium mb-2">Eligibility</h2>
                        <p>
                            New Pro subscribers are eligible for a full refund
                            within 7 days of initial purchase.
                        </p>
                    </section>
                    <section>
                        <h2 class="text-white font-medium mb-2">
                            How to Request
                        </h2>
                        <p>
                            Email support@genapps.online with your account email
                            and "Refund Request" in the subject.
                        </p>
                    </section>
                    <section>
                        <h2 class="text-white font-medium mb-2">Processing</h2>
                        <p>
                            Refunds are processed within 5-10 business days to
                            your original payment method.
                        </p>
                    </section>
                    <section>
                        <h2 class="text-white font-medium mb-2">Exclusions</h2>
                        <p>
                            Refunds are not available for: renewals, Enterprise
                            plans (custom terms apply), or accounts that
                            violated our terms.
                        </p>
                    </section>
                    <section>
                        <h2 class="text-white font-medium mb-2">Contact</h2>
                        <p>
                            For refund inquiries, contact support@genapps.online
                        </p>
                        <p class="mt-2 text-[#666666]">
                            Payments processed by Paddle. Operated by MUNEEB UR
                            REHMAN.
                        </p>
                    </section>
                </div>
            </div>
        </div>
    </main>

    <Footer />
</Layout>
