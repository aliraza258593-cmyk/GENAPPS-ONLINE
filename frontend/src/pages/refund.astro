---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Refund Policy">
    <Header />

    <main class="pt-24 min-h-screen">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <h1 class="text-4xl font-bold font-display text-white mb-8">
                Refund Policy
            </h1>
            <div class="prose prose-invert prose-gray max-w-none">
                <p class="text-gray-400 mb-6">Last updated: January 2024</p>

                <div class="glass rounded-2xl p-8 space-y-6">
                    <section>
                        <h2 class="text-xl font-bold text-white mb-4">
                            7-Day Money-Back Guarantee
                        </h2>
                        <p class="text-gray-400 leading-relaxed">
                            We offer a 7-day money-back guarantee for all new
                            paid subscriptions. If you're not satisfied with
                            GENAPPS.ONLINE within the first 7 days of your
                            subscription, you can request a full refund.
                        </p>
                    </section>

                    <section>
                        <h2 class="text-xl font-bold text-white mb-4">
                            How to Request a Refund
                        </h2>
                        <p class="text-gray-400 leading-relaxed">
                            To request a refund, contact our support team at
                            support@genapps.online within 7 days of your initial
                            purchase. Include your account email and reason for
                            the refund request. Refunds are typically processed
                            within 5-10 business days.
                        </p>
                    </section>

                    <section>
                        <h2 class="text-xl font-bold text-white mb-4">
                            Eligibility
                        </h2>
                        <ul class="text-gray-400 space-y-2">
                            <li>• First-time subscribers only</li>
                            <li>• Request must be within 7 days of purchase</li>
                            <li>
                                • Account must not have violated our Terms of
                                Service
                            </li>
                            <li>• One refund per customer</li>
                        </ul>
                    </section>

                    <section>
                        <h2 class="text-xl font-bold text-white mb-4">
                            After the 7-Day Period
                        </h2>
                        <p class="text-gray-400 leading-relaxed">
                            After 7 days, subscriptions are non-refundable. You
                            can cancel your subscription at any time, and you'll
                            continue to have access until the end of your
                            current billing period.
                        </p>
                    </section>

                    <section>
                        <h2 class="text-xl font-bold text-white mb-4">
                            Cancellation
                        </h2>
                        <p class="text-gray-400 leading-relaxed">
                            You can cancel your subscription at any time from
                            your account settings. Your access will continue
                            until the end of your current billing period. No
                            prorated refunds are given for partial months.
                        </p>
                    </section>

                    <section>
                        <h2 class="text-xl font-bold text-white mb-4">
                            Exceptions
                        </h2>
                        <p class="text-gray-400 leading-relaxed">
                            Refunds may be considered outside the 7-day window
                            in cases of billing errors, duplicate charges, or
                            service outages exceeding 24 hours. Contact support
                            for assistance.
                        </p>
                    </section>

                    <section>
                        <h2 class="text-xl font-bold text-white mb-4">
                            Contact
                        </h2>
                        <p class="text-gray-400 leading-relaxed">
                            For refund requests or billing questions, contact
                            billing@genapps.online
                        </p>
                    </section>
                </div>
            </div>
        </div>
    </main>

    <Footer />
</Layout>
