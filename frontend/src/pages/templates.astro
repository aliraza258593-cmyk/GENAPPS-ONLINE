---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import AuthModal from "../components/AuthModal.astro";

const templates = [
    {
        name: "E-commerce Store",
        icon: "🛒",
        description:
            "Full-featured online store with product grid, cart, and checkout",
        prompt: "Create a modern e-commerce store",
        tags: ["React", "Commerce"],
    },
    {
        name: "SaaS Landing",
        icon: "🚀",
        description:
            "High-converting landing page with hero, features, and pricing",
        prompt: "Build a SaaS landing page",
        tags: ["Landing", "SaaS"],
    },
    {
        name: "Portfolio",
        icon: "🎨",
        description: "Creative portfolio to showcase your work",
        prompt: "Design a creative portfolio",
        tags: ["Personal", "Portfolio"],
    },
    {
        name: "Dashboard",
        icon: "📊",
        description: "Data-rich dashboard with charts and tables",
        prompt: "Create an admin dashboard",
        tags: ["Dashboard", "Admin"],
    },
    {
        name: "Blog",
        icon: "📝",
        description: "Modern blog with article cards",
        prompt: "Build a modern blog",
        tags: ["Blog", "Content"],
    },
    {
        name: "Restaurant",
        icon: "🍕",
        description: "Restaurant site with menu and reservations",
        prompt: "Design a restaurant website",
        tags: ["Food", "Business"],
    },
    {
        name: "Real Estate",
        icon: "🏠",
        description: "Property listings with search",
        prompt: "Create a real estate website",
        tags: ["Real Estate", "Listings"],
    },
    {
        name: "Fitness App",
        icon: "💪",
        description: "App landing for fitness products",
        prompt: "Build a fitness app landing",
        tags: ["Fitness", "App"],
    },
    {
        name: "Startup",
        icon: "✨",
        description: "Clean startup landing page",
        prompt: "Design a startup landing page",
        tags: ["Startup", "Landing"],
    },
    {
        name: "Event",
        icon: "🎉",
        description: "Event page with schedule and registration",
        prompt: "Create an event website",
        tags: ["Events", "Conference"],
    },
    {
        name: "Agency",
        icon: "🏢",
        description: "Digital agency with case studies",
        prompt: "Build an agency website",
        tags: ["Agency", "Services"],
    },
    {
        name: "Documentation",
        icon: "📚",
        description: "Technical docs with navigation",
        prompt: "Design a documentation site",
        tags: ["Docs", "Technical"],
    },
];
---

<Layout title="Templates">
    <Header />
    <AuthModal />

    <main class="pt-14 min-h-screen">
        <div class="container-premium py-16 lg:py-24">
            <!-- Header -->
            <div class="text-center mb-12">
                <h1 class="text-2xl lg:text-3xl font-semibold text-white mb-3">
                    Templates
                </h1>
                <p class="text-sm text-[#666666]">
                    Start with a template or describe your own design
                </p>
            </div>

            <!-- Templates Grid -->
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-3">
                {
                    templates.map((template) => (
                        <button
                            class="template-card p-5 bg-[#0a0a0a] border border-[rgba(255,255,255,0.06)] rounded-xl text-left hover:border-[rgba(255,255,255,0.12)] transition-all group"
                            data-prompt={template.prompt}
                        >
                            <div class="flex items-start justify-between mb-3">
                                <div class="text-2xl">{template.icon}</div>
                                <svg
                                    class="w-4 h-4 text-[#333333] group-hover:text-[#888888] transition-colors"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M14 5l7 7m0 0l-7 7m7-7H3"
                                    />
                                </svg>
                            </div>
                            <h3 class="text-sm font-medium text-white mb-1 group-hover:text-white">
                                {template.name}
                            </h3>
                            <p class="text-xs text-[#666666] mb-3">
                                {template.description}
                            </p>
                            <div class="flex gap-1">
                                {template.tags.map((tag) => (
                                    <span class="px-1.5 py-0.5 text-[9px] bg-[rgba(255,255,255,0.04)] text-[#666666] rounded">
                                        {tag}
                                    </span>
                                ))}
                            </div>
                        </button>
                    ))
                }
            </div>

            <!-- CTA -->
            <div class="text-center mt-12">
                <a
                    href="/builder"
                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-black text-sm font-medium rounded-lg hover:bg-[#e5e5e5] transition-colors"
                >
                    Create Custom Design
                </a>
            </div>
        </div>
    </main>

    <Footer />
</Layout>

<script is:inline>
    document.querySelectorAll(".template-card").forEach((card) => {
        card.addEventListener("click", function () {
            window.location.href =
                "/builder?prompt=" + encodeURIComponent(this.dataset.prompt);
        });
    });
</script>
