---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import AuthModal from "../components/AuthModal.astro";
---

<Layout title="Contact">
    <Header />
    <AuthModal />

    <main class="pt-24 min-h-screen">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="text-center mb-12">
                <h1
                    class="text-4xl sm:text-5xl font-bold font-display text-white mb-4"
                >
                    Get in <span class="gradient-text">Touch</span>
                </h1>
                <p class="text-gray-400 max-w-2xl mx-auto">
                    Have questions? We'd love to hear from you. Send us a
                    message and we'll respond as soon as possible.
                </p>
            </div>

            <div class="grid md:grid-cols-2 gap-8">
                <div class="glass rounded-2xl p-8">
                    <h2 class="text-xl font-bold text-white mb-6">
                        Send us a message
                    </h2>
                    <form id="contact-form" class="space-y-4">
                        <div>
                            <label
                                class="block text-sm font-medium text-gray-300 mb-2"
                                >Name</label
                            >
                            <input
                                type="text"
                                name="name"
                                required
                                class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:outline-none focus:border-primary-500"
                                placeholder="Your name"
                            />
                        </div>
                        <div>
                            <label
                                class="block text-sm font-medium text-gray-300 mb-2"
                                >Email</label
                            >
                            <input
                                type="email"
                                name="email"
                                required
                                class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:outline-none focus:border-primary-500"
                                placeholder="you@example.com"
                            />
                        </div>
                        <div>
                            <label
                                class="block text-sm font-medium text-gray-300 mb-2"
                                >Subject</label
                            >
                            <select
                                name="subject"
                                class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:outline-none focus:border-primary-500"
                            >
                                <option value="general">General Inquiry</option>
                                <option value="support"
                                    >Technical Support</option
                                >
                                <option value="billing">Billing Question</option
                                >
                                <option value="enterprise"
                                    >Enterprise Sales</option
                                >
                                <option value="partnership">Partnership</option>
                            </select>
                        </div>
                        <div>
                            <label
                                class="block text-sm font-medium text-gray-300 mb-2"
                                >Message</label
                            >
                            <textarea
                                name="message"
                                rows="5"
                                required
                                class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:outline-none focus:border-primary-500 resize-none"
                                placeholder="How can we help?"></textarea>
                        </div>
                        <button
                            type="submit"
                            class="w-full btn-primary py-3 rounded-xl text-white font-semibold"
                        >
                            Send Message
                        </button>
                    </form>
                </div>

                <div class="space-y-6">
                    <div class="glass rounded-2xl p-8">
                        <h2 class="text-xl font-bold text-white mb-6">
                            Other ways to reach us
                        </h2>
                        <div class="space-y-6">
                            <div class="flex items-start gap-4">
                                <div
                                    class="w-12 h-12 rounded-xl bg-primary-500/20 flex items-center justify-center flex-shrink-0"
                                >
                                    <svg
                                        class="w-6 h-6 text-primary-400"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                        ></path>
                                    </svg>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-white">
                                        Email
                                    </h3>
                                    <p class="text-gray-400">
                                        support@genapps.online
                                    </p>
                                </div>
                            </div>
                            <div class="flex items-start gap-4">
                                <div
                                    class="w-12 h-12 rounded-xl bg-primary-500/20 flex items-center justify-center flex-shrink-0"
                                >
                                    <svg
                                        class="w-6 h-6 text-primary-400"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
                                        ></path>
                                    </svg>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-white">
                                        Live Chat
                                    </h3>
                                    <p class="text-gray-400">
                                        Available Mon-Fri, 9am-5pm EST
                                    </p>
                                </div>
                            </div>
                            <div class="flex items-start gap-4">
                                <div
                                    class="w-12 h-12 rounded-xl bg-primary-500/20 flex items-center justify-center flex-shrink-0"
                                >
                                    <svg
                                        class="w-6 h-6 text-primary-400"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"
                                        ></path>
                                    </svg>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-white">
                                        Twitter
                                    </h3>
                                    <p class="text-gray-400">@genapps_online</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="glass rounded-2xl p-8">
                        <h3 class="font-semibold text-white mb-4">
                            Response Times
                        </h3>
                        <ul class="space-y-2 text-gray-400">
                            <li class="flex items-center gap-2">
                                <span class="w-2 h-2 rounded-full bg-green-500"
                                ></span>
                                General inquiries: 24-48 hours
                            </li>
                            <li class="flex items-center gap-2">
                                <span class="w-2 h-2 rounded-full bg-blue-500"
                                ></span>
                                Technical support: 12-24 hours
                            </li>
                            <li class="flex items-center gap-2">
                                <span class="w-2 h-2 rounded-full bg-amber-500"
                                ></span>
                                Enterprise: Same business day
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <Footer />
</Layout>

<script>
    document.getElementById("contact-form")?.addEventListener("submit", (e) => {
        e.preventDefault();
        alert("Thank you for your message! We will get back to you soon.");
        (e.target as HTMLFormElement).reset();
    });
</script>
