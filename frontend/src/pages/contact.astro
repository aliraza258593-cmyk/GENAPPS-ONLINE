---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Contact Us">
    <Header />

    <main class="pt-14 min-h-screen">
        <div class="container-premium py-16 lg:py-24">
            <div class="text-center mb-12">
                <h1 class="text-2xl lg:text-3xl font-semibold text-white mb-3">
                    Contact
                </h1>
                <p class="text-sm text-[#666666]">Get in touch with us</p>
            </div>

            <div class="max-w-md mx-auto">
                <!-- Contact Info -->
                <div
                    class="p-5 bg-[#0a0a0a] border border-[rgba(255,255,255,0.06)] rounded-xl mb-8"
                >
                    <div class="text-xs text-[#888888] mb-1">Email</div>
                    <a
                        href="mailto:support@genapps.online"
                        class="text-sm text-white hover:underline"
                        >support@genapps.online</a
                    >
                    <p class="text-xs text-[#444444] mt-2">
                        We typically respond within 24 hours
                    </p>
                </div>

                <!-- Contact Form -->
                <form id="contact-form" class="space-y-4">
                    <div>
                        <label class="block text-xs text-[#888888] mb-2"
                            >Name</label
                        >
                        <input
                            type="text"
                            name="name"
                            required
                            class="w-full px-4 py-3 bg-[#0a0a0a] border border-[rgba(255,255,255,0.06)] rounded-lg text-white text-sm focus:outline-none focus:border-[rgba(255,255,255,0.12)]"
                            placeholder="Your name"
                        />
                    </div>
                    <div>
                        <label class="block text-xs text-[#888888] mb-2"
                            >Email</label
                        >
                        <input
                            type="email"
                            name="email"
                            required
                            class="w-full px-4 py-3 bg-[#0a0a0a] border border-[rgba(255,255,255,0.06)] rounded-lg text-white text-sm focus:outline-none focus:border-[rgba(255,255,255,0.12)]"
                            placeholder="you@example.com"
                        />
                    </div>
                    <div>
                        <label class="block text-xs text-[#888888] mb-2"
                            >Subject</label
                        >
                        <select
                            name="subject"
                            required
                            class="w-full px-4 py-3 bg-[#0a0a0a] border border-[rgba(255,255,255,0.06)] rounded-lg text-white text-sm focus:outline-none focus:border-[rgba(255,255,255,0.12)]"
                        >
                            <option value="">Select a topic</option>
                            <option value="general">General Inquiry</option>
                            <option value="support">Technical Support</option>
                            <option value="billing">Billing Question</option>
                            <option value="feedback">Feedback</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs text-[#888888] mb-2"
                            >Message</label
                        >
                        <textarea
                            name="message"
                            rows="4"
                            required
                            class="w-full px-4 py-3 bg-[#0a0a0a] border border-[rgba(255,255,255,0.06)] rounded-lg text-white text-sm focus:outline-none focus:border-[rgba(255,255,255,0.12)] resize-none"
                            placeholder="How can we help?"></textarea>
                    </div>
                    <button
                        type="submit"
                        id="submit-btn"
                        class="w-full py-3 bg-white text-black text-sm font-medium rounded-lg hover:bg-[#e5e5e5] transition-colors"
                    >
                        Send Message
                    </button>
                    <div id="form-status" class="hidden text-center text-sm">
                    </div>
                </form>

                <!-- Business Info for Paddle -->
                <div
                    class="mt-10 pt-8 border-t border-[rgba(255,255,255,0.06)]"
                >
                    <p class="text-xs text-[#444444] text-center">
                        Operated by MUNEEB UR REHMAN<br />
                        Payments processed by Paddle
                    </p>
                </div>
            </div>
        </div>
    </main>

    <Footer />
</Layout>

<script is:inline>
    var API_URL = "http://localhost:3001/api";

    document
        .getElementById("contact-form")
        ?.addEventListener("submit", async function (e) {
            e.preventDefault();
            var formData = new FormData(this);
            var submitBtn = document.getElementById("submit-btn");
            var statusEl = document.getElementById("form-status");

            submitBtn.disabled = true;
            submitBtn.textContent = "Sending...";

            try {
                var response = await fetch(API_URL + "/contact", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        name: formData.get("name"),
                        email: formData.get("email"),
                        subject: formData.get("subject"),
                        message: formData.get("message"),
                    }),
                });

                var data = await response.json();

                if (data.success) {
                    statusEl.classList.remove("hidden", "text-red-400");
                    statusEl.classList.add("text-green-400");
                    statusEl.textContent =
                        "Message sent! We'll get back to you soon.";
                    this.reset();
                } else {
                    throw new Error(data.error || "Failed to send");
                }
            } catch (error) {
                statusEl.classList.remove("hidden", "text-green-400");
                statusEl.classList.add("text-red-400");
                statusEl.textContent =
                    "Failed to send. Please email us directly.";
            }

            submitBtn.disabled = false;
            submitBtn.textContent = "Send Message";
        });
</script>
