---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import AuthModal from "../components/AuthModal.astro";

const models = [
  { id: "gemini-flash", name: "Gemini Flash", badge: "Free" },
  { id: "gpt-5.2", name: "GPT-5.2", badge: "Pro" },
  { id: "claude-opus-4.5", name: "Claude Opus 4.5", badge: "Pro" },
];

const templates = [
  {
    name: "E-commerce Store",
    icon: "🛒",
    prompt:
      "Create a modern e-commerce store with product grid, cart, and checkout",
  },
  {
    name: "SaaS Landing",
    icon: "🚀",
    prompt:
      "Build a SaaS landing page with hero, features, pricing, and testimonials",
  },
  {
    name: "Portfolio",
    icon: "🎨",
    prompt:
      "Design a creative portfolio with project gallery and about section",
  },
  {
    name: "Dashboard",
    icon: "📊",
    prompt:
      "Create an admin dashboard with charts, tables, and sidebar navigation",
  },
  {
    name: "Blog",
    icon: "📝",
    prompt:
      "Build a modern blog with article cards, categories, and newsletter signup",
  },
  {
    name: "Restaurant",
    icon: "🍕",
    prompt: "Design a restaurant website with menu, reservations, and gallery",
  },
];
---

<Layout title="AI Website Builder">
  <Header />
  <AuthModal />

  <main class="pt-24 pb-16 min-h-screen bg-gradient-to-b from-gray-50 to-white">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <!-- Hero -->
      <div class="text-center mb-12">
        <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-4">
          What do you want to build?
        </h1>
        <p class="text-xl text-gray-600">
          Describe your website and AI will create it in seconds
        </p>
      </div>

      <!-- Main Builder Card -->
      <div
        class="bg-white rounded-2xl border border-gray-200 p-8 shadow-xl shadow-gray-200/50 mb-12"
      >
        <!-- Model & Options Row -->
        <div
          class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6"
        >
          <div class="flex items-center gap-4">
            <select
              id="model-select"
              class="px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 text-gray-700 font-medium text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500"
            >
              {
                models.map((model) => (
                  <option value={model.id}>
                    {model.name} ({model.badge})
                  </option>
                ))
              }
            </select>
          </div>

          <div class="flex items-center gap-3">
            <span class="text-sm font-medium text-gray-600">Deep Thinking</span>
            <button
              id="deep-thinking-toggle"
              class="relative w-12 h-7 rounded-full bg-gray-200 transition-all"
              data-enabled="false"
            >
              <div
                class="absolute left-1 top-1 w-5 h-5 rounded-full bg-white shadow transition-all"
              >
              </div>
            </button>
          </div>
        </div>

        <!-- Textarea -->
        <textarea
          id="prompt-input"
          class="w-full h-36 p-5 rounded-xl bg-gray-50 border border-gray-200 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 resize-none text-base mb-6"
          placeholder="Describe your dream website... e.g., 'Create a modern SaaS landing page with hero section, features grid, pricing table, and testimonials'"
        ></textarea>

        <!-- Bottom Row -->
        <div
          class="flex flex-col sm:flex-row items-center justify-between gap-4"
        >
          <div class="flex items-center gap-2 text-sm">
            <span class="font-bold text-indigo-600" id="credits-display"
              >5 Credits</span
            >
            <span class="text-gray-500">left today</span>
          </div>

          <button
            id="build-btn"
            class="group px-8 py-4 rounded-xl bg-indigo-600 text-white font-bold text-base shadow-lg shadow-indigo-500/30 hover:bg-indigo-700 hover:shadow-xl transition-all flex items-center gap-3"
          >
            <span>Build Website</span>
            <svg
              class="w-5 h-5 group-hover:translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </button>
        </div>
      </div>

      <!-- Templates Grid -->
      <div class="mb-12">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">
          Quick templates
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          {
            templates.map((template) => (
              <button
                class="template-btn p-4 rounded-xl bg-white border border-gray-200 hover:border-indigo-300 hover:shadow-lg transition-all text-left group"
                data-prompt={template.prompt}
              >
                <div class="text-2xl mb-2">{template.icon}</div>
                <div class="text-sm font-medium text-gray-800 group-hover:text-indigo-600 transition-colors">
                  {template.name}
                </div>
              </button>
            ))
          }
        </div>
      </div>

      <!-- Progress Section -->
      <div
        id="progress-section"
        class="hidden bg-white rounded-2xl border border-gray-200 p-6 mb-8"
      >
        <div class="flex items-center gap-4 mb-4">
          <div
            class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center"
          >
            <svg
              class="w-4 h-4 text-indigo-600 animate-spin"
              fill="none"
              viewBox="0 0 24 24"
            >
              <circle
                class="opacity-25"
                cx="12"
                cy="12"
                r="10"
                stroke="currentColor"
                stroke-width="4"></circle>
              <path
                class="opacity-75"
                fill="currentColor"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
              ></path>
            </svg>
          </div>
          <div>
            <div class="font-semibold text-gray-900" id="progress-text">
              Generating your website...
            </div>
            <div class="text-sm text-gray-500">
              This usually takes 15-30 seconds
            </div>
          </div>
        </div>
        <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden">
          <div
            id="progress-bar"
            class="h-full bg-gradient-to-r from-indigo-500 to-purple-500 rounded-full transition-all duration-500"
            style="width: 0%"
          >
          </div>
        </div>
      </div>

      <!-- Preview Section -->
      <div id="preview-section" class="hidden">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-bold text-gray-900">
            Your website is ready! 🎉
          </h2>
        </div>

        <div
          class="bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-xl mb-6"
        >
          <div
            class="flex items-center gap-2 px-4 py-3 bg-gray-50 border-b border-gray-200"
          >
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
              <div class="w-3 h-3 rounded-full bg-green-400"></div>
            </div>
            <div class="flex-1 text-center text-sm text-gray-500">
              preview.genapps.online
            </div>
          </div>
          <iframe id="preview-frame" class="w-full h-[500px] bg-white"></iframe>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-wrap gap-4 justify-center">
          <button
            id="preview-new-tab"
            class="px-6 py-3 rounded-xl bg-gray-100 text-gray-700 font-semibold hover:bg-gray-200 transition-colors flex items-center gap-2"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              ></path>
            </svg>
            Open in New Tab
          </button>
          <button
            id="export-github"
            class="px-6 py-3 rounded-xl bg-gray-900 text-white font-semibold hover:bg-gray-800 transition-colors flex items-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
            Export to GitHub
          </button>
          <button
            id="deploy-vercel"
            class="px-6 py-3 rounded-xl bg-indigo-600 text-white font-semibold hover:bg-indigo-700 transition-colors flex items-center gap-2 shadow-lg shadow-indigo-500/30"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 22.525H0l12-21.05 12 21.05z"></path>
            </svg>
            Deploy to Vercel
          </button>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script is:inline>
  var API_URL = "http://localhost:3001/api";
  var selectedModel = "gemini-flash";
  var deepThinking = false;
  var generatedCode = "";

  function getToken() {
    return localStorage.getItem("genapps_token");
  }
  function getUser() {
    var userData = localStorage.getItem("genapps_user");
    return userData ? JSON.parse(userData) : null;
  }

  document
    .getElementById("model-select")
    ?.addEventListener("change", function () {
      selectedModel = this.value;
    });

  document
    .getElementById("deep-thinking-toggle")
    ?.addEventListener("click", function () {
      deepThinking = !deepThinking;
      var indicator = this.querySelector("div");
      if (deepThinking) {
        this.classList.remove("bg-gray-200");
        this.classList.add("bg-indigo-500");
        if (indicator) indicator.style.transform = "translateX(20px)";
      } else {
        this.classList.add("bg-gray-200");
        this.classList.remove("bg-indigo-500");
        if (indicator) indicator.style.transform = "translateX(0)";
      }
    });

  document.querySelectorAll(".template-btn").forEach(function (btn) {
    btn.addEventListener("click", function () {
      var prompt = btn.dataset.prompt || "";
      var textarea = document.getElementById("prompt-input");
      if (textarea) textarea.value = prompt;
    });
  });

  function animateProgress() {
    return new Promise(function (resolve) {
      var section = document.getElementById("progress-section");
      var bar = document.getElementById("progress-bar");
      if (section) section.classList.remove("hidden");
      var steps = [25, 50, 75, 100];
      var i = 0;
      function nextStep() {
        if (i < steps.length) {
          if (bar) bar.style.width = steps[i] + "%";
          i++;
          setTimeout(nextStep, 800);
        } else {
          resolve();
        }
      }
      nextStep();
    });
  }

  document.getElementById("build-btn")?.addEventListener("click", function () {
    var token = getToken();
    var user = getUser();
    if (!token || !user) {
      document.getElementById("auth-modal")?.classList.remove("hidden");
      return;
    }

    var promptInput = document.getElementById("prompt-input");
    var prompt = promptInput ? promptInput.value.trim() : "";
    if (!prompt) {
      alert("Please describe your website first");
      return;
    }

    var buildBtn = document.getElementById("build-btn");
    buildBtn.disabled = true;
    buildBtn.innerHTML =
      '<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg><span>Generating...</span>';

    animateProgress();

    fetch(API_URL + "/generate", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Authorization: "Bearer " + token,
      },
      body: JSON.stringify({
        prompt: prompt,
        model: selectedModel,
        deepThinking: deepThinking,
      }),
    })
      .then(function (response) {
        return response.json().then(function (data) {
          if (!response.ok) {
            if (data.upgradeRequired) {
              window.location.href = "/pricing";
              return;
            }
            throw new Error(data.error || "Generation failed");
          }
          return data;
        });
      })
      .then(function (data) {
        if (!data) return;
        generatedCode = data.code;
        renderPreview(generatedCode, data.watermark);
        if (data.credits) {
          var cd = document.getElementById("credits-display");
          if (cd)
            cd.textContent =
              (data.credits.unlimited ? "∞" : data.credits.credits) +
              " Credits";
        }
      })
      .catch(function (error) {
        alert(error.message || "Failed to generate");
      })
      .finally(function () {
        buildBtn.disabled = false;
        buildBtn.innerHTML =
          '<span>Build Website</span><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>';
        setTimeout(function () {
          document.getElementById("progress-section")?.classList.add("hidden");
        }, 500);
      });
  });

  function renderPreview(code, showWatermark) {
    document.getElementById("preview-section")?.classList.remove("hidden");
    var frame = document.getElementById("preview-frame");
    var html =
      '<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><script src="https://cdn.tailwindcss.com"><\/script><script src="https://unpkg.com/react@18/umd/react.production.min.js"><\/script><script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"><\/script><script src="https://unpkg.com/@babel/standalone/babel.min.js"><\/script></head><body><div id="root"></div><script type="text/babel">' +
      code +
      '\nconst root = ReactDOM.createRoot(document.getElementById("root"));root.render(React.createElement(App));<\/script></body></html>';
    if (frame) frame.srcdoc = html;
    document
      .getElementById("preview-section")
      ?.scrollIntoView({ behavior: "smooth" });
  }

  document
    .getElementById("preview-new-tab")
    ?.addEventListener("click", function () {
      if (!generatedCode) {
        alert("Generate a website first");
        return;
      }
      var html =
        '<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><script src="https://cdn.tailwindcss.com"><\/script><script src="https://unpkg.com/react@18/umd/react.production.min.js"><\/script><script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"><\/script><script src="https://unpkg.com/@babel/standalone/babel.min.js"><\/script></head><body><div id="root"></div><script type="text/babel">' +
        generatedCode +
        '\nconst root = ReactDOM.createRoot(document.getElementById("root"));root.render(React.createElement(App));<\/script></body></html>';
      window.open(
        URL.createObjectURL(new Blob([html], { type: "text/html" })),
        "_blank",
      );
    });

  document
    .getElementById("export-github")
    ?.addEventListener("click", function () {
      var user = getUser();
      if (!user || user.plan === "free") {
        alert("GitHub export is a Pro feature.");
        window.location.href = "/pricing";
      }
    });

  document
    .getElementById("deploy-vercel")
    ?.addEventListener("click", function () {
      var user = getUser();
      if (!user || user.plan === "free") {
        alert("Vercel deploy is a Pro feature.");
        window.location.href = "/pricing";
      }
    });

  document.addEventListener("DOMContentLoaded", function () {
    var user = getUser();
    if (user) {
      var cd = document.getElementById("credits-display");
      if (cd)
        cd.textContent =
          (user.plan === "free" ? user.credits : "∞") + " Credits";
    }
  });
</script>
