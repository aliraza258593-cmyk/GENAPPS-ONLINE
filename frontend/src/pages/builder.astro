---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import AuthModal from "../components/AuthModal.astro";

const models = [
  {
    id: "gemini-flash",
    name: "Gemini Flash",
    badge: "Free",
    icon: "✨",
    description: "Fast & Free",
  },
  {
    id: "gpt-5.2",
    name: "GPT-5.2",
    badge: "Popular",
    icon: "🚀",
    description: "Best quality",
  },
  {
    id: "claude-opus-4.5",
    name: "Claude 4.5",
    badge: "Pro",
    icon: "🧠",
    description: "Creative",
  },
  {
    id: "deepseek",
    name: "DeepSeek",
    badge: "New",
    icon: "🔮",
    description: "Powerful",
  },
];

const templates = [
  {
    name: "E-commerce",
    icon: "🛒",
    prompt:
      "Create a modern e-commerce store with product grid, cart, checkout, and customer reviews",
  },
  {
    name: "SaaS Landing",
    icon: "🚀",
    prompt:
      "Build a SaaS landing page with hero, features grid, pricing tables, testimonials, and FAQ",
  },
  {
    name: "Portfolio",
    icon: "🎨",
    prompt:
      "Design a creative portfolio with project gallery, about section, skills, and contact form",
  },
  {
    name: "Dashboard",
    icon: "📊",
    prompt:
      "Create an admin dashboard with charts, tables, sidebar navigation, and notifications",
  },
  {
    name: "Blog",
    icon: "📝",
    prompt:
      "Build a modern blog with article cards, categories, search, and newsletter signup",
  },
  {
    name: "Restaurant",
    icon: "🍕",
    prompt:
      "Design a restaurant website with menu, reservations, gallery, and customer reviews",
  },
];
---

<Layout title="AI Website Builder">
  <Header />
  <AuthModal />

  <main class="pt-16 min-h-screen">
    <div class="container-premium py-12 lg:py-16">
      <!-- Header -->
      <div class="text-center mb-10">
        <div
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gradient-to-r from-purple-500/10 to-pink-500/10 border border-purple-500/20 mb-5"
        >
          <div class="pulse-dot"></div>
          <span class="text-sm text-purple-300">AI Website Builder</span>
        </div>
        <h1 class="text-3xl lg:text-4xl font-bold text-white mb-3">
          What do you want to <span
            class="bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent"
            >build</span
          >?
        </h1>
        <p class="text-[#7a7a82] max-w-lg mx-auto">
          Describe your website in detail and our AI will generate a stunning,
          production-ready full-stack website
        </p>
      </div>

      <!-- Main Builder Card -->
      <div class="max-w-2xl mx-auto mb-10">
        <div
          class="bg-[#121218]/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 lg:p-8 shadow-xl"
        >
          <!-- Prompt Input -->
          <div class="mb-6">
            <label class="block text-sm text-white mb-3 font-medium"
              >Describe your website in detail</label
            >
            <textarea
              id="prompt-input"
              rows="5"
              class="w-full px-4 py-4 bg-[#18181f] border border-white/8 rounded-xl text-white text-base placeholder-[#55555d] focus:outline-none focus:border-purple-500/30 focus:ring-2 focus:ring-purple-500/10 transition-all resize-none"
              placeholder="Be specific! E.g., 'A modern SaaS landing page for a project management tool. Include a hero section with a demo video placeholder, 6 feature cards with icons, a pricing section with 3 tiers, customer testimonials with photos, an FAQ accordion, and a footer with newsletter signup. Use a dark purple theme with gradient accents.'"
            ></textarea>
            <p class="text-xs text-[#55555d] mt-2">
              💡 Tip: The more detail you provide, the better the result.
              Mention sections, colors, features, and style preferences.
            </p>
          </div>

          <!-- Model Selection -->
          <div class="mb-6">
            <label class="block text-sm text-white mb-3 font-medium"
              >Choose AI Model</label
            >
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
              {
                models.map((model, index) => (
                  <button
                    data-model={model.id}
                    class={`model-btn flex flex-col items-center gap-1 p-4 rounded-xl text-center transition-all ${index === 0 ? "bg-gradient-to-br from-purple-600/20 to-pink-600/20 border-2 border-purple-500/50 shadow-lg shadow-purple-500/10" : "bg-[#18181f] border border-white/8 hover:border-white/20"}`}
                  >
                    <span class="text-2xl">{model.icon}</span>
                    <span class="text-xs font-medium text-white">
                      {model.name}
                    </span>
                    <span
                      class={`text-[10px] px-2 py-0.5 rounded-full ${model.badge === "Free" ? "bg-green-500/20 text-green-400" : model.badge === "Popular" ? "bg-purple-500/20 text-purple-300" : model.badge === "New" ? "bg-blue-500/20 text-blue-300" : "bg-white/10 text-[#7a7a82]"}`}
                    >
                      {model.badge}
                    </span>
                  </button>
                ))
              }
            </div>
          </div>

          <!-- Generate Button -->
          <button
            id="generate-btn"
            class="w-full py-4 bg-gradient-to-r from-purple-600 to-pink-600 text-white text-base font-semibold rounded-xl hover:from-purple-500 hover:to-pink-500 transition-all shadow-lg shadow-purple-500/25 flex items-center justify-center gap-2"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
            <span>Generate Website</span>
          </button>

          <!-- Progress Bar -->
          <div id="progress-container" class="hidden mt-6">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm text-[#7a7a82]" id="progress-status"
                >Analyzing your requirements...</span
              >
              <span class="text-sm font-medium text-white" id="progress-percent"
                >0%</span
              >
            </div>
            <div class="h-2 bg-[#1e1e26] rounded-full overflow-hidden">
              <div
                id="progress-bar"
                class="h-full bg-gradient-to-r from-purple-500 to-pink-500 rounded-full transition-all duration-500"
                style="width: 0%"
              >
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Templates -->
      <div class="max-w-2xl mx-auto mb-12">
        <p class="text-sm text-[#7a7a82] mb-4 text-center">
          Or start with a template:
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          {
            templates.map((template) => (
              <button
                data-prompt={template.prompt}
                class="template-btn p-4 bg-[#121218] border border-white/8 rounded-xl text-left hover:border-purple-500/30 hover:bg-purple-500/5 transition-all group"
              >
                <div class="text-2xl mb-2 group-hover:scale-110 transition-transform">
                  {template.icon}
                </div>
                <div class="text-sm font-medium text-[#a0a0a8] group-hover:text-white transition-colors">
                  {template.name}
                </div>
              </button>
            ))
          }
        </div>
      </div>

      <!-- Preview Panel -->
      <div id="preview-panel" class="max-w-5xl mx-auto hidden">
        <div class="flex items-center justify-between mb-4">
          <div>
            <h2 class="text-lg font-semibold text-white">Your Website</h2>
            <p class="text-sm text-[#7a7a82]">
              Preview your generated website below
            </p>
          </div>
          <div class="flex items-center gap-3">
            <button
              id="copy-btn"
              class="flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 text-white text-sm font-medium rounded-lg hover:bg-white/10 transition-all"
            >
              📋 Copy Code
            </button>
            <button
              id="new-btn"
              class="flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 text-white text-sm font-medium rounded-lg hover:bg-white/10 transition-all"
            >
              ✨ New
            </button>
            <button
              id="export-btn"
              class="flex items-center gap-2 px-5 py-2 bg-gradient-to-r from-purple-600 to-pink-600 text-white text-sm font-semibold rounded-lg hover:from-purple-500 hover:to-pink-500 transition-all shadow-lg shadow-purple-500/20"
            >
              🚀 Deploy to Vercel
            </button>
          </div>
        </div>

        <!-- Browser Frame -->
        <div
          class="bg-[#121218] border border-white/10 rounded-2xl overflow-hidden shadow-2xl shadow-purple-500/5"
        >
          <!-- Browser Bar -->
          <div
            class="flex items-center gap-3 px-5 py-4 border-b border-white/5 bg-[#18181f]"
          >
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
            </div>
            <div class="flex-1 flex items-center justify-center">
              <div
                class="px-4 py-1.5 bg-[#0c0c0f] rounded-lg text-xs text-[#7a7a82] flex items-center gap-2"
              >
                <svg
                  class="w-3 h-3 text-green-400"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z"
                    clip-rule="evenodd"></path>
                </svg>
                preview.genapps.online
              </div>
            </div>
            <div class="flex items-center gap-2">
              <button
                class="p-1.5 text-[#55555d] hover:text-white transition-colors"
                title="Refresh"
              >
                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                  ></path>
                </svg>
              </button>
              <button
                class="p-1.5 text-[#55555d] hover:text-white transition-colors"
                title="Open in new tab"
              >
                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  ></path>
                </svg>
              </button>
            </div>
          </div>

          <!-- Preview Iframe -->
          <div class="bg-white aspect-[16/10] relative">
            <iframe
              id="preview-iframe"
              class="w-full h-full border-0"
              sandbox="allow-scripts"></iframe>

            <!-- Loading Overlay -->
            <div
              id="preview-loading"
              class="hidden absolute inset-0 bg-gradient-to-br from-slate-950 via-purple-950 to-slate-950 flex items-center justify-center"
            >
              <div class="text-center">
                <div class="relative w-16 h-16 mx-auto mb-4">
                  <div
                    class="absolute inset-0 border-4 border-purple-500/20 rounded-full"
                  >
                  </div>
                  <div
                    class="absolute inset-0 border-4 border-transparent border-t-purple-500 rounded-full animate-spin"
                  >
                  </div>
                </div>
                <p class="text-white font-medium mb-1">
                  Generating your website...
                </p>
                <p class="text-[#7a7a82] text-sm">
                  This usually takes 15-30 seconds
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Success Message -->
        <div
          id="success-message"
          class="hidden mt-6 p-4 bg-green-500/10 border border-green-500/20 rounded-xl"
        >
          <div class="flex items-center gap-3">
            <div
              class="w-10 h-10 bg-green-500/20 rounded-full flex items-center justify-center text-green-400"
            >
              ✓
            </div>
            <div>
              <p class="text-white font-medium">
                Website generated successfully!
              </p>
              <p class="text-sm text-[#7a7a82]">
                Your full-stack website is ready. Deploy it or copy the code.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script is:inline>
  var API_URL = "http://localhost:3001/api";
  var selectedModel = "gemini-flash";
  var generatedCode = "";

  // Check for prompt in URL
  var urlParams = new URLSearchParams(window.location.search);
  var promptParam = urlParams.get("prompt");
  if (promptParam) {
    document.getElementById("prompt-input").value = promptParam;
  }

  // Model selection
  document.querySelectorAll(".model-btn").forEach((btn) => {
    btn.addEventListener("click", function () {
      document.querySelectorAll(".model-btn").forEach((b) => {
        b.classList.remove(
          "bg-gradient-to-br",
          "from-purple-600/20",
          "to-pink-600/20",
          "border-2",
          "border-purple-500/50",
          "shadow-lg",
          "shadow-purple-500/10",
        );
        b.classList.add("bg-[#18181f]", "border", "border-white/8");
      });
      this.classList.remove("bg-[#18181f]", "border", "border-white/8");
      this.classList.add(
        "bg-gradient-to-br",
        "from-purple-600/20",
        "to-pink-600/20",
        "border-2",
        "border-purple-500/50",
        "shadow-lg",
        "shadow-purple-500/10",
      );
      selectedModel = this.dataset.model;
    });
  });

  // Template selection
  document.querySelectorAll(".template-btn").forEach((btn) => {
    btn.addEventListener("click", function () {
      document.getElementById("prompt-input").value = this.dataset.prompt;
      document.getElementById("prompt-input").focus();
    });
  });

  // New button
  document.getElementById("new-btn")?.addEventListener("click", function () {
    document.getElementById("prompt-input").value = "";
    document.getElementById("preview-panel")?.classList.add("hidden");
    document.getElementById("progress-container")?.classList.add("hidden");
    document.getElementById("success-message")?.classList.add("hidden");
    document.getElementById("prompt-input").focus();
    window.scrollTo({ top: 0, behavior: "smooth" });
  });

  // Generate button
  document
    .getElementById("generate-btn")
    ?.addEventListener("click", async function () {
      var prompt = document.getElementById("prompt-input").value.trim();
      if (!prompt) {
        alert("Please describe your website in detail");
        return;
      }

      var token = localStorage.getItem("genapps_token");
      if (!token) {
        document.getElementById("auth-modal")?.classList.remove("hidden");
        return;
      }

      // Show progress
      document.getElementById("progress-container")?.classList.remove("hidden");
      document.getElementById("preview-panel")?.classList.remove("hidden");
      document.getElementById("preview-loading")?.classList.remove("hidden");
      document.getElementById("success-message")?.classList.add("hidden");

      this.disabled = true;
      this.innerHTML =
        '<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg><span>Generating...</span>';

      // Scroll to preview
      setTimeout(() => {
        document
          .getElementById("preview-panel")
          ?.scrollIntoView({ behavior: "smooth", block: "start" });
      }, 100);

      var progress = 0;
      var progressMessages = [
        "Analyzing your requirements...",
        "Understanding design preferences...",
        "Generating component structure...",
        "Building interactive elements...",
        "Adding animations and effects...",
        "Optimizing for responsiveness...",
        "Finalizing code...",
      ];
      var msgIndex = 0;

      var progressInterval = setInterval(function () {
        progress += Math.random() * 10;
        if (progress > 95) progress = 95;
        document.getElementById("progress-bar").style.width = progress + "%";
        document.getElementById("progress-percent").textContent =
          Math.floor(progress) + "%";

        if (progress > (msgIndex + 1) * 14) {
          msgIndex = Math.min(msgIndex + 1, progressMessages.length - 1);
          document.getElementById("progress-status").textContent =
            progressMessages[msgIndex];
        }
      }, 400);

      try {
        var response = await fetch(API_URL + "/generate", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: "Bearer " + token,
          },
          body: JSON.stringify({ prompt: prompt, model: selectedModel }),
        });

        var data = await response.json();

        clearInterval(progressInterval);
        document.getElementById("progress-bar").style.width = "100%";
        document.getElementById("progress-percent").textContent = "100%";
        document.getElementById("progress-status").textContent = "Complete! ✨";

        if (data.code) {
          generatedCode = data.code;
          document.getElementById("preview-iframe").srcdoc = data.code;
          document.getElementById("preview-loading")?.classList.add("hidden");
          document
            .getElementById("success-message")
            ?.classList.remove("hidden");
        } else if (data.error) {
          alert("Error: " + data.error);
          document.getElementById("preview-loading")?.classList.add("hidden");
        }
      } catch (error) {
        clearInterval(progressInterval);
        alert("Generation failed. Please try again.");
        document.getElementById("preview-loading")?.classList.add("hidden");
      }

      this.disabled = false;
      this.innerHTML =
        '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg><span>Generate Website</span>';
    });

  // Copy code
  document.getElementById("copy-btn")?.addEventListener("click", function () {
    if (generatedCode) {
      navigator.clipboard.writeText(generatedCode);
      this.innerHTML = "✓ Copied!";
      setTimeout(() => {
        this.innerHTML = "📋 Copy Code";
      }, 2000);
    }
  });
</script>
